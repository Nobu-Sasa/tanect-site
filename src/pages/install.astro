---
// 家族モニター向け インストール案内ページ（/install）
//
// 公開LPのナビからはリンクしない「身内向け」ページ。
// 第一波モニターには、申し込み後の返信メール／LINE でこのページのURLを送る。
// サイト全体が noindex,nofollow（BaseLayout）なので検索には載らない。
//
// ⚠️ 差し替え必須：下の2つのリンクを、発行済みの実URLに書き換えてください。
//   - ANDROID_INVITE_LINK … Firebase App Distribution の monitors グループ「招待リンク」
//   - IOS_TESTFLIGHT_LINK  … App Store Connect → TestFlight 外部テストの「公開リンク」（Beta Review 承認後）
// （手順の出典：tanect-management/04_customers/monitor_onboarding.md §1・§3）
import BaseLayout from '../layouts/BaseLayout.astro';

const ANDROID_INVITE_LINK = 'https://appdistribution.firebase.dev/your-android-link-here';
const IOS_TESTFLIGHT_LINK = 'https://testflight.apple.com/join/your-ios-code-here';

// リンクが未発行のうちは true にしておくと、ボタンを「準備中」表示にできる
const ANDROID_READY = false;
const IOS_READY = false;

const HOME_URL = import.meta.env.BASE_URL;
const RELEASE_NOTES_URL = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/release-notes`;

const androidSteps = [
  'このページを <strong>Androidスマホ</strong> で開き、下のボタンを押します。',
  '<strong>Googleアカウント</strong>でサインインし、利用規約に同意します。',
  '画面の案内に従って <strong>「App Tester」アプリ</strong> を入れます。',
  '<strong>Tanect Home</strong> をインストールします。<br />※「提供元不明のアプリ」の確認が出たら、画面の案内に従って許可してください（アプリストア以外からのお届けのためです）。',
  '次の新しいバージョンが出ると、App Tester からお知らせが届きます。',
];

const iosSteps = [
  'まず App Store から <strong>「TestFlight」アプリ</strong> を入れておきます。',
  'このページを <strong>iPhone</strong> で開き、下のボタンを押すと TestFlight が開きます。',
  '<strong>「インストール」</strong>をタップします。',
  '次の新しいバージョンが出ると、TestFlight からお知らせが届きます。',
];
---

<BaseLayout
  title="インストール方法 — Tanect Home（家族モニター）"
  description="Tanect Home 家族モニターのみなさん向けの、iPhone・Android それぞれのインストール手順のご案内です。"
>
  <header class="page-head">
    <a href={HOME_URL} class="logo" aria-label="Tanect Home トップへ">
      <img
        class="logo-mark"
        src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/images/app-icon.png`}
        width="32"
        height="32"
        alt=""
        aria-hidden="true"
      />
      <span class="logo-text">Tanect</span>
    </a>
  </header>

  <main class="install">
    <div class="install-inner">
      <section class="intro">
        <span class="badge">🌱 家族モニターのみなさんへ</span>
        <h1 class="intro-title">インストール方法のご案内</h1>
        <p class="intro-lead">
          Tanect Home を試してくださり、ありがとうございます。<br />
          お使いのスマホにあわせて、下の手順どおりに進めてください。<br />
          むずかしい設定はありません。途中でつまずいても大丈夫です。
        </p>
        <p class="intro-pick">
          お使いの端末は <strong>iPhone</strong> ですか？ <strong>Android</strong> ですか？<br />
          <span class="intro-pick-note">わからないときは、ご家族にきいてみてくださいね。</span>
        </p>
      </section>

      <div class="cards">
        <!-- iPhone -->
        <section class="card" id="iphone" aria-labelledby="iphone-title">
          <div class="card-head">
            <span class="card-emoji" aria-hidden="true">🍎</span>
            <h2 class="card-title" id="iphone-title">iPhone をお使いの方</h2>
          </div>
          <ol class="steps">
            {iosSteps.map((s, i) => (
              <li class="step">
                <span class="step-num" aria-hidden="true">{i + 1}</span>
                <span class="step-text" set:html={s} />
              </li>
            ))}
          </ol>
          <div class="card-cta">
            {IOS_READY ? (
              <a
                href={IOS_TESTFLIGHT_LINK}
                class="btn btn-accent"
                target="_blank"
                rel="noopener noreferrer"
              >
                iPhone でインストールする
              </a>
            ) : (
              <span class="btn btn-disabled" aria-disabled="true">準備中（リンクは個別にお送りします）</span>
            )}
            <p class="card-note">※ うまくいかないときは、この案内をお送りしたメール（または LINE）に返信でご連絡ください。</p>
          </div>
        </section>

        <!-- Android -->
        <section class="card" id="android" aria-labelledby="android-title">
          <div class="card-head">
            <span class="card-emoji" aria-hidden="true">🤖</span>
            <h2 class="card-title" id="android-title">Android をお使いの方</h2>
          </div>
          <ol class="steps">
            {androidSteps.map((s, i) => (
              <li class="step">
                <span class="step-num" aria-hidden="true">{i + 1}</span>
                <span class="step-text" set:html={s} />
              </li>
            ))}
          </ol>
          <div class="card-cta">
            {ANDROID_READY ? (
              <a
                href={ANDROID_INVITE_LINK}
                class="btn btn-accent"
                target="_blank"
                rel="noopener noreferrer"
              >
                Android でインストールする
              </a>
            ) : (
              <span class="btn btn-disabled" aria-disabled="true">準備中（リンクは個別にお送りします）</span>
            )}
            <p class="card-note">※ うまくいかないときは、この案内をお送りしたメール（または LINE）に返信でご連絡ください。</p>
          </div>
        </section>
      </div>

      <section class="notice" aria-labelledby="notice-title">
        <div class="notice-head">
          <span class="notice-emoji" aria-hidden="true">✉️</span>
          <h2 class="notice-title" id="notice-title">アプリを開いてアカウントを作るとき</h2>
        </div>
        <p class="notice-text">
          インストールが終わってアプリを開くと、はじめにアカウントを作ります。<br />
          そのとき、確認のための <strong>6けたの数字（コード）</strong> がメールで届きます。<br />
          このコードを入力すると、登録が完了します。
        </p>
        <p class="notice-text">
          メールは <strong>DoNotReply@tanect.app</strong> から届きます。<br />
          <strong>迷惑メール・プロモーションのフォルダ</strong>に入ってしまうことがあるので、受信トレイに見当たらないときは、そちらものぞいてみてください。
        </p>
        <p class="notice-note">※ コードは、届いてから <strong>10分のあいだ</strong> ご利用いただけます。見つからないときや時間が過ぎたときは、登録の画面からもう一度お送りできます。</p>
        <p class="notice-note">※ それでも届かないときは、この案内をお送りしたメール（または LINE）に返信でご連絡ください。</p>
      </section>

      <section class="help">
        <h2 class="help-title">困ったときは</h2>
        <p class="help-text">
          途中で止まってしまっても、まったく問題ありません。<br />
          画面の写真を撮って、この案内をお送りしたメール（または LINE）に返信していただければ、こちらで一緒に確認します。<br />
          インストール後は、アプリ内の画面右上の人アイコン →「お問い合わせ」からもご連絡いただけます。
        </p>
        <div class="help-links">
          <a href={RELEASE_NOTES_URL} class="help-back">📓 最新の更新内容（リリースノート）を見る</a>
          <a href={HOME_URL} class="help-back">← Tanect Home のトップへもどる</a>
        </div>
      </section>
    </div>
  </main>

  <footer class="page-foot">
    <p class="page-foot-copy">© 2026 Tanect Home</p>
  </footer>
</BaseLayout>

<style>
  /* ── ヘッダー（最小：ロゴのみ） ── */
  .page-head {
    border-bottom: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.9);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-md);
    font-weight: 700;
  }

  .logo-mark {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: block;
  }

  .logo-text {
    font-size: 20px;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  /* ── 本文 ── */
  .install {
    padding: var(--space-3xl) var(--space-md);
    background: linear-gradient(180deg, var(--color-accent-soft) 0%, #ffffff 320px);
  }

  .install-inner {
    max-width: var(--content-max);
    margin-inline: auto;
  }

  .intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .intro-title {
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: var(--lh-snug);
    color: var(--color-text);
    letter-spacing: 0.012em;
  }

  .intro-lead {
    font-size: var(--fs-body);
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .intro-pick {
    margin-top: var(--space-sm);
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--color-text);
  }

  .intro-pick-note {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── 端末カード ── */
  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .card-emoji {
    font-size: 28px;
    line-height: 1;
  }

  .card-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .step-num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    color: var(--color-accent-text);
    font-size: 15px;
    font-weight: 700;
    line-height: 1;
  }

  .step-text {
    font-size: 16px;
    line-height: 1.8;
    color: var(--color-text);
    padding-top: 2px;
  }

  .card-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .card-cta .btn {
    width: 100%;
    max-width: 360px;
  }

  .btn-disabled {
    background: var(--color-badge-bg);
    color: var(--color-text-muted);
    cursor: not-allowed;
    font-size: var(--fs-small);
  }

  .btn-disabled:hover {
    transform: none;
    box-shadow: none;
  }

  .card-note {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    text-align: center;
  }

  /* ── 確認メールの注意 ── */
  .notice {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-border-subtle);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
  }

  .notice-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .notice-emoji {
    font-size: 26px;
    line-height: 1;
  }

  .notice-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .notice-text {
    font-size: 16px;
    line-height: 1.9;
    color: var(--color-text);
  }

  .notice-text + .notice-text {
    margin-top: var(--space-md);
  }

  .notice-note {
    margin-top: var(--space-md);
    font-size: var(--fs-small);
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  /* ── 困ったときは ── */
  .help {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-bg-soft);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .help-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .help-text {
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .help-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
    justify-content: center;
    margin-top: var(--space-lg);
  }

  .help-back {
    display: inline-block;
    font-size: 14px;
    color: var(--color-accent-ink);
    text-decoration: underline;
  }

  /* ── フッター ── */
  .page-foot {
    padding: var(--space-xl) var(--space-md);
    text-align: center;
    border-top: 1px solid var(--color-border-subtle);
  }

  .page-foot-copy {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── Tablet and up ── */
  @media (min-width: 768px) {
    .intro-title {
      font-size: var(--fs-h1-lg);
    }

    .cards {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }
</style>
