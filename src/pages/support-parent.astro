---
// 見守り役向け「離れて暮らす親をサポートする」案内ページ（/support-parent）
//
// first-settings.astro（親本人向けの設定案内）の続きにあたる、見守り役（子世代）向けページ。
// 親の端末で「委任」をONにしたあと、見守り役が自分の端末から
// ①親の設定の代行 ②親の予定の代理入力 ③親の活動の見守り を行う手順を案内する。
// サイト全体が noindex,nofollow（BaseLayout）。
//
// 出典（ラベル・挙動）：Tanect2 PersonalSettings.razor / Calendar.razor / WeeklySummary.razor / Analysis.razor
// ⚠️ 役割名は公開版アプリに合わせ「見守り役」で統一（最新版は「サポーター」）。
// ⚠️ スクショ差し替え：下の screens/support-*.png はまだ未配置。
//    画像が無いあいだは「差し替え予定」プレースホルダが表示される（onerror フォールバック）。
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const HOME_URL = import.meta.env.BASE_URL;
const INSTALL_URL = `${base}/install`;
const FAMILY_SETUP_URL = `${base}/family-setup`;
const FIRST_SETTINGS_URL = `${base}/first-settings`;
const RELEASE_NOTES_URL = `${base}/release-notes`;

// 離れた親をサポートする4ステップ（カード）
const steps = [
  {
    emoji: '🤝',
    title: '① まず、親の端末で「委任」をONに',
    where: '親の個人設定 →「その他」',
    shot: 'support-delegate.png',
    alt: '親の個人設定「その他」にある、設定／分析を見守り役へ委任のトグル画面',
    lead: 'サポートのスタートは、2つのスイッチをONにすることから。<strong>この設定は親の端末（親の画面）で行います。</strong>離れていても大丈夫、電話などで一緒に進めてみてください。',
    points: [
      '<strong>設定を見守り役へ委任</strong> … ONにすると、見守り役が親の<strong>設定や予定</strong>をかわりに整えられるようになります。',
      '<strong>分析を見守り役へ委任</strong> … ONにすると、見守り役が親の<strong>暮らしのまとめ（活動）</strong>を見守れるようになります。',
      'どちらも「個人設定 →『その他』」にあります（<strong>親世代の画面にだけ</strong>表示されます）。<strong>あとからいつでもOFF</strong>にできます。',
    ],
  },
  {
    emoji: '⚙️',
    title: '② 親の設定を、かわりに整える',
    where: '自分の個人設定 →「誰の設定？」で親を選ぶ',
    shot: 'support-settings.png',
    alt: '自分の個人設定の上部「誰の設定？」で親を選び、親の表示設定などを代理で整える画面',
    lead: '「設定を見守り役へ委任」がONになると、<strong>見守り役ご自身の端末</strong>の「個人設定」の上に<strong>「誰の設定？」</strong>が出ます。ここで親を選ぶと、<strong>委任のスイッチ以外の設定も</strong>、親のかわりに整えられます。',
    points: [
      '親を選ぶと「<strong>○○さんの設定を代理で編集します。変更はその方の設定として保存されます</strong>」と表示されます。',
      `<strong>文字サイズ・やさしい操作モード・お名前</strong>など、<a href="${FIRST_SETTINGS_URL}">設定のととのえ方</a>でご紹介した設定を、見守り役が親のかわりに調整できます。`,
      '離れていても、親の「見えにくい」「使いにくい」を、その場で整えてあげられます。',
    ],
  },
  {
    emoji: '🗓',
    title: '③ 親の予定を、かわりに入れる',
    where: '下のメニュー →「予定」',
    shot: 'support-schedule.png',
    alt: '予定画面で「誰の予定？」から親を選び、予定を追加する画面',
    lead: '見守り役は、自分の端末から親の予定を入れられます。まず画面上の<strong>「誰の予定？」で親を選ぶ</strong>と、「○○さんの予定を表示しています」に切り替わります。',
    points: [
      '<strong>予定を追加</strong> … その日かぎりの予定（通院・来客など）は、日付を選んで<strong>「予定を追加」</strong>から入れます。追加・編集は<strong>親の予定として記録</strong>されます。',
      '<strong>ルーティーン</strong> … 毎日のお薬や水やりなど<strong>くりかえしの予定</strong>は、「ルーティーン管理」からまとめて設定できます。',
      '親が<strong>やさしい操作モード</strong>で予定を入れにくいときも、見守り役がかわりに整えてあげられます。',
    ],
  },
  {
    emoji: '📊',
    title: '④ 親の活動を、そっと見守る',
    where: '下のメニュー →「知る」→「活動を見る」',
    shot: 'support-activity.png',
    alt: '「知る」→「活動を見る」で分析対象に親を選び、活動件数・体調・気分・時間帯を見る画面',
    lead: '「知る」をひらき、<strong>「活動を見る」</strong>を選びます。<strong>「分析対象」で親を選ぶ</strong>と、親の暮らしのようすが見られます（<strong>分析委任をONにした親</strong>が候補に出ます）。',
    points: [
      '<strong>活動件数</strong> … どんな活動を、どれくらいしているかをまとめて見られます。',
      '<strong>体調・気分</strong> … 日々の移り変わりや、気になる日が分かります。',
      '<strong>操作している時間帯</strong> … いつアプリを使っているか（暮らしのリズム）が分かります。',
    ],
  },
];
---

<BaseLayout
  title="離れて暮らす親をサポートする — Tanect Home（家族モニター）"
  description="離れて暮らす見守り役（お子さんなど）が、親の設定・予定・活動をかわりに整えて見守るための手順を、スクリーンショット付きでご案内します。"
>
  <header class="page-head">
    <a href={HOME_URL} class="logo" aria-label="Tanect Home トップへ">
      <img
        class="logo-mark"
        src={`${base}/images/app-icon.png`}
        width="32"
        height="32"
        alt=""
        aria-hidden="true"
      />
      <span class="logo-text">Tanect</span>
    </a>
  </header>

  <main class="setup">
    <div class="setup-inner">
      <section class="intro">
        <span class="badge">🤝 離れて暮らすご家族へ</span>
        <h1 class="intro-title">離れて暮らす<wbr />親をサポートする</h1>
        <p class="intro-lead">
          離れて暮らしていても、見守り役（お子さんなど）が、<wbr />親の暮らしをそっと支えられます。<br />
          必要なのは、つぎの4つのステップだけです。
        </p>
        <p class="intro-pick">
          まずは親の端末で「委任」をONに。<br />
          <span class="intro-pick-note">設定はあとからいつでも変えられます。気になるところから、少しずつで大丈夫です。</span>
        </p>
      </section>

      <!-- 離れた親をサポートする4ステップ -->
      <div class="cards steps-cards">
        {steps.map((g) => (
          <section class="card step-card">
            <div class="card-head">
              <span class="card-emoji" aria-hidden="true">{g.emoji}</span>
              <div>
                <h2 class="card-title">{g.title}</h2>
                <p class="card-role">{g.where}</p>
              </div>
            </div>
            <div class="setting-body">
              <div class="shot">
                <div class="shot-frame">
                  <img
                    src={`${base}/screens/${g.shot}`}
                    alt={g.alt}
                    loading="lazy"
                    onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
                  />
                  <div class="shot-ph" aria-hidden="true" hidden>
                    <span>📱 スクリーンショット差し替え予定</span>
                    <code>screens/{g.shot}</code>
                  </div>
                </div>
              </div>
              <div class="setting-text">
                <p class="setting-lead" set:html={g.lead} />
                <ul class="setting-points">
                  {g.points.map((p) => (
                    <li set:html={p} />
                  ))}
                </ul>
              </div>
            </div>
          </section>
        ))}
      </div>

      <section class="notice" aria-labelledby="notice-title">
        <div class="notice-head">
          <span class="notice-emoji" aria-hidden="true">💡</span>
          <h2 class="notice-title" id="notice-title">知っておくと安心なこと</h2>
        </div>
        <ul class="notice-list">
          <li>委任は <strong>あとからいつでもOFF</strong> にできます。気軽に試してみてください。</li>
          <li>「活動を見る」の対象に出るのは、<strong>分析委任をONにした親だけ</strong>です。親のプライバシーは守られます。</li>
          <li>かわりに行った設定や予定は、<strong>親本人の設定・予定として保存</strong>され、親の画面にもそのまま表示されます。</li>
          <li>困ったときは、画面右上の人アイコン →「お問い合わせ」からご連絡いただけます。</li>
        </ul>
      </section>

      <section class="help">
        <h2 class="help-title">困ったときは</h2>
        <p class="help-text">
          うまくいかなくても、まったく問題ありません。<br />
          画面の写真を撮って、この案内をお送りしたメール（または LINE）に返信していただければ、こちらで一緒に確認します。<br />
          アプリ内の画面右上の人アイコン →「お問い合わせ」からもご連絡いただけます。
        </p>
        <div class="help-links">
          <a href={FIRST_SETTINGS_URL} class="help-back">🌱 設定のととのえ方を見る</a>
          <a href={FAMILY_SETUP_URL} class="help-back">👪 家族のつくり方を見る</a>
          <a href={INSTALL_URL} class="help-back">📲 インストール方法のご案内を見る</a>
          <a href={RELEASE_NOTES_URL} class="help-back">📓 最新の更新内容（リリースノート）を見る</a>
          <a href={HOME_URL} class="help-back">← Tanect Home のトップへもどる</a>
        </div>
      </section>
    </div>
  </main>

  <footer class="page-foot">
    <p class="page-foot-copy">© 2026 Tanect Home</p>
  </footer>
</BaseLayout>

<style>
  /* ── ヘッダー（最小：ロゴのみ） ── */
  .page-head {
    border-bottom: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.9);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-md);
    font-weight: 700;
  }

  .logo-mark {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: block;
  }

  .logo-text {
    font-size: 20px;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  /* ── 本文 ── */
  .setup {
    padding: var(--space-3xl) var(--space-md);
    background: linear-gradient(180deg, var(--color-accent-soft) 0%, #ffffff 320px);
  }

  .setup-inner {
    max-width: var(--content-max);
    margin-inline: auto;
  }

  .intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .intro-title {
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: var(--lh-snug);
    color: var(--color-text);
    letter-spacing: 0.012em;
    /* 文節の途中で折らず、<wbr> を入れた位置でのみ改行する */
    word-break: keep-all;
  }

  .intro-lead {
    font-size: var(--fs-body);
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .intro-pick {
    margin-top: var(--space-sm);
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--color-text);
  }

  .intro-pick-note {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── カード ── */
  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .card-emoji {
    font-size: 28px;
    line-height: 1;
  }

  .card-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .card-role {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── 設定の中身（スクショ＋説明） ── */
  .setting-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .shot {
    position: relative;
    width: 100%;
    max-width: 220px;
    flex-shrink: 0;
  }

  .shot-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 19;
    border-radius: 28px;
    background: linear-gradient(148deg, #1a1a2e 0%, #030213 100%);
    padding: 10px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .shot-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
  }

  .shot-ph {
    position: absolute;
    inset: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    border-radius: 20px;
    background: linear-gradient(148deg, #e9ebef 0%, #ffffff 100%);
    color: var(--color-text-muted);
    font-size: 13px;
    text-align: center;
    padding: var(--space-md);
  }

  .shot-ph[hidden] {
    display: none;
  }

  .shot-ph code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    padding: 2px 8px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 4px;
  }

  .setting-text {
    width: 100%;
  }

  .setting-lead {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .setting-points {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-left: 1.2em;
    list-style: disc;
  }

  .setting-points li {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* カード本文中のリンク（例：設定のととのえ方へ） */
  .setting-points :global(a) {
    color: var(--color-accent-ink);
    text-decoration: underline;
  }

  /* ── 知っておくと安心なこと ── */
  .notice {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-border-subtle);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
  }

  .notice-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .notice-emoji {
    font-size: 26px;
    line-height: 1;
  }

  .notice-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .notice-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-left: 1.2em;
    list-style: disc;
  }

  .notice-list li {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* ── 困ったときは ── */
  .help {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-bg-soft);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .help-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .help-text {
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .help-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
    justify-content: center;
    margin-top: var(--space-lg);
  }

  .help-back {
    display: inline-block;
    font-size: 14px;
    color: var(--color-accent-ink);
    text-decoration: underline;
  }

  /* ── フッター ── */
  .page-foot {
    padding: var(--space-xl) var(--space-md);
    text-align: center;
    border-top: 1px solid var(--color-border-subtle);
  }

  .page-foot-copy {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── Tablet and up ── */
  @media (min-width: 768px) {
    .intro-title {
      font-size: var(--fs-h1-lg);
    }

    /* スクショと説明を横並びに */
    .setting-body {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-2xl);
    }

    .setting-text {
      flex: 1;
    }
  }
</style>
