//    参照: tanect-management/01_strategy/brand_foundation_setup.md §5「一括更新リスト」
import PageLayout from '../layouts/PageLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<PageLayout
