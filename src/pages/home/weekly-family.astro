---
// 機能紹介「今週の家族 ＆ 思い出をさがす」案内ページ（/weekly-family）
//
// アプリ内「知る」→タブ「今週の家族」（WeeklySummary.razor）の機能ショーケース。
// 毎週日曜朝に届く週次AIサマリー（今週の家族）と、その画面内の「思い出をさがす」
// （Discovery.razor のハイブリッド検索）を、view-activity.astro と同じテイスト
// （やさしい敬語・カード・暖色トークン）で紹介する。
// サイト全体が noindex,nofollow（BaseLayout）。
//
// 出典（ラベル・挙動）：Tanect2 WeeklySummary.razor / Discovery.razor、release-notes L50。
// ⚠️ スクショ差し替え：下の screens/weekly-*.png はまだ未配置。
//    画像が無いあいだは「差し替え予定」プレースホルダが表示される（onerror フォールバック）。
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const HOME_URL = import.meta.env.BASE_URL.replace(/\/$/, '') + '/home/';
const FAMILY_SETUP_URL = `${base}/home/family-setup`;
const FIRST_SETTINGS_URL = `${base}/home/first-settings`;
const FAMILY_ROLES_URL = `${base}/home/family-roles`;
const SUPPORT_PARENT_URL = `${base}/home/support-parent`;
const VIEW_ACTIVITY_URL = `${base}/home/view-activity`;

// ① 今週の家族（週次AIサマリー）の説明ポイント
const weeklyPoints = [
  '<strong>毎週日曜の朝</strong>に、前の週（日曜〜土曜の7日間）の家族のようすが、ひとつの<strong>物語</strong>になって届きます。',
  '完了した活動・気分・体調・家族からの応援を、AI が<strong>やさしい言葉</strong>でまとめます。点数をつけたり、前の週とくらべたりはしません。',
  'その週の<strong>お気に入り写真の上位3枚</strong>もいっしょに並びます。',
  '<strong>過去12週ぶん</strong>をさかのぼって読み返せます。電波がないときも、前回ひらいた内容を表示します。',
];

// ② 思い出をさがす（Discovery）の使い方 ― ①「今週の家族」と同じカード＋箇条書きでそろえる
const discoverySteps = [
  {
    title: '自然な言葉でさがす',
    text: '「<strong>家族で海に行ったのは？</strong>」「<strong>散歩したのはいつ？</strong>」のように入力すると、内容の近い週の物語カードが<strong>すぐに</strong>出てきます（このときは AI を動かさず、すばやく表示します）。',
  },
  {
    title: 'おまかせ発見',
    text: '「<strong>1年前のきょう</strong>」「<strong>この季節の思い出</strong>」を、入力しなくてもそっと提案します。タップするだけで、ふとした思い出にふれられます。',
  },
  {
    title: 'お名前でしぼる',
    text: 'ご家族のお名前（例：「<strong>はる子さんが登場するのは？</strong>」）を入れると、その方が出てくる週にしぼってさがせます。',
  },
  {
    title: 'まとめて答えてもらう',
    text: '気になるときだけ「<strong>まとめて答えてもらう</strong>」を押すと、AI が質問に沿ってまとめてお答えします。どの週を参照したかも、いっしょに教えてくれます。',
  },
];

// 知っておくと安心なこと
const notices = [
  '今週の家族と思い出をさがすは、<strong>家族の中だけ</strong>で共有されます。「分析のおまかせ」と同じ、見守りの輪の中の機能です。',
  '今週の家族は<strong>毎週日曜の朝</strong>に届きます。まだ届いていないときは、つぎの日曜をお待ちください。',
];
---

<BaseLayout
  title="今週の家族 ＆ 思い出をさがす — Tanect Home（家族モニター）"
  description="Tanect Home の「今週の家族」機能のご案内。毎週日曜の朝に届く週次のAIまとめ（家族の一週間の物語とお気に入り写真）と、過去の週を自然な言葉でさがせる「思い出をさがす」を、画面付きでやさしくご紹介します。"
>
  <header class="page-head">
    <a href={HOME_URL} class="logo" aria-label="Tanect Home トップへ">
      <img
        class="logo-mark"
        src={`${base}/images/app-icon.png`}
        width="32"
        height="32"
        alt=""
        aria-hidden="true"
      />
      <span class="logo-text">Tanect<span class="logo-home"> Home</span></span>
    </a>
  </header>

  <main class="setup">
    <div class="setup-inner">
      <section class="intro">
        <span class="badge">📖 今週の家族</span>
        <h1 class="intro-title">家族の一週間を、<wbr />物語で受け取る</h1>
        <p class="intro-lead">
          毎週日曜の朝、家族のこの一週間が、<wbr />ひとつのやさしい物語になって届きます。<br />
          そして、これまでの週を<wbr />「思い出」として、自然な言葉でさがせます。
        </p>
        <p class="intro-pick-note">「知る」→ タブ「今週の家族」からひらけます。</p>
      </section>

      <!-- ひらき方（下メニュー →「知る」→ タブ「今週の家族」） -->
      <section class="open" aria-labelledby="open-title">
        <h2 class="open-title" id="open-title">ひらき方</h2>
        <ol class="open-steps">
          <li class="open-step">
            <p class="open-cap"><span class="open-num" aria-hidden="true">1</span>下のメニューの<strong>「知る」</strong>をタップ</p>
            <figure class="open-figure">
              <img
                src={`${base}/screens/activity-nav-know.png`}
                alt="画面下のメニューで「知る」が選ばれている様子（私の／みんなの／予定／知る）"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
              />
              <figcaption class="open-ph" aria-hidden="true" hidden>
                <span>🖼 画像差し替え予定</span>
                <code>screens/activity-nav-know.png</code>
              </figcaption>
            </figure>
          </li>
          <li class="open-step">
            <p class="open-cap"><span class="open-num" aria-hidden="true">2</span>上のタブで<strong>「今週の家族」</strong>をえらぶ</p>
            <figure class="open-figure">
              <img
                src={`${base}/screens/weekly-tab.png`}
                alt="「知る」の上部タブで「今週の家族」が選ばれている様子（今週の家族／活動を見る）"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
              />
              <figcaption class="open-ph" aria-hidden="true" hidden>
                <span>🖼 画像差し替え予定</span>
                <code>screens/weekly-tab.png</code>
              </figcaption>
            </figure>
          </li>
        </ol>
      </section>

      <!-- ① 今週の家族（週次AIサマリー） -->
      <section class="card weekly-card" aria-labelledby="weekly-title">
        <div class="card-head">
          <span class="card-emoji" aria-hidden="true">📖</span>
          <div>
            <h2 class="card-title" id="weekly-title">① 今週の家族 ― 一週間の物語が届く</h2>
            <p class="card-role">毎週日曜の朝に、そっと</p>
          </div>
        </div>
        <div class="setting-body">
          <div class="shot">
            <div class="shot-frame">
              <img
                src={`${base}/screens/weekly-summary.png`}
                alt="毎週日曜の朝に届く「今週の家族」。家族の一週間をまとめた物語とお気に入り写真上位3枚が並び、見出しの右に「音声で聞く」ボタンがある画面"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
              />
              <div class="shot-ph" aria-hidden="true" hidden>
                <span>📱 スクリーンショット差し替え予定</span>
                <code>screens/weekly-summary.png</code>
              </div>
            </div>
          </div>
          <div class="setting-text">
            <p class="setting-lead">
              選んだご家族の<strong>一週間のようす</strong>を、AI が<strong>ひとつの物語</strong>にまとめてお届けします。
            </p>
            <ul class="setting-points">
              {weeklyPoints.map((p) => (
                <li set:html={p} />
              ))}
            </ul>
            <div class="audio-callout">
              <span class="audio-callout-icon" aria-hidden="true">🔊</span>
              <div class="audio-callout-body">
                <h3 class="audio-callout-title">音声で聞く ― 耳でも受け取れます</h3>
                <p class="audio-callout-text">
                  見出しの右の<strong>「音声で聞く」</strong>を押すと、その週の物語を<strong>やさしい声</strong>で読み上げます。物語といっしょに音声も<strong>毎週自動で</strong>用意されるので、<strong>文字を読むのがつらいとき</strong>や<strong>年配のご家族</strong>も、耳でゆっくり受け取れます。もう一度押すと止まります。
                </p>
                <p class="audio-callout-note">
                  なお、お名前には<strong>読み方（ふりがな）</strong>を設定でき、登録しておくとお名前も正しく読み上げられます（ご高齢の方のぶんは、ご家族が<strong>代わりに設定</strong>できます）。
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ② 思い出をさがす（Discovery）― ①「今週の家族」と同じカード構成にそろえる -->
      <section class="card ai-card" aria-labelledby="discovery-title">
        <div class="card-head">
          <span class="card-emoji" aria-hidden="true">🔎</span>
          <div>
            <h2 class="card-title" id="discovery-title">② 思い出をさがす ― これまでの週を、ことばでたどる</h2>
            <p class="card-role">ことばを入れるだけ。気になるときだけ AI に</p>
          </div>
        </div>
        <div class="setting-body">
          <div class="shot">
            <div class="shot-frame">
              <img
                src={`${base}/screens/weekly-discovery.png`}
                alt="「思い出をさがす」の検索画面。ことばを入力する欄と「1年前のきょう」「この季節の思い出」のおまかせ発見カードが並ぶ"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
              />
              <div class="shot-ph" aria-hidden="true" hidden>
                <span>📱 スクリーンショット差し替え予定</span>
                <code>screens/weekly-discovery.png</code>
              </div>
            </div>
          </div>
          <div class="setting-text">
            <p class="setting-lead">
              同じ「今週の家族」の画面で、過去にとどいた物語を<strong>自然な言葉</strong>でさがせます。
              まずは<strong>すばやく</strong>近い週を表示し、気になるときだけ AI がまとめて答えます。
            </p>
            <ul class="setting-points">
              {discoverySteps.map((f) => (
                <li set:html={`<strong>${f.title}</strong>：${f.text}`} />
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="notice" aria-labelledby="notice-title">
        <div class="notice-head">
          <span class="notice-emoji" aria-hidden="true">💡</span>
          <h2 class="notice-title" id="notice-title">知っておくと安心なこと</h2>
        </div>
        <ul class="notice-list">
          {notices.map((n) => (
            <li set:html={n} />
          ))}
        </ul>
      </section>

      <section class="help">
        <h2 class="help-title">関連ページ</h2>
        <p class="help-text">
          グラフでの見える化や、家族を見守る手順とあわせてご覧ください。
        </p>
        <div class="help-links">
          <a href={VIEW_ACTIVITY_URL} class="help-back">📈 活動を見る（AIまとめ）を見る</a>
          <a href={SUPPORT_PARENT_URL} class="help-back">🤝 離れた親をサポートする方法を見る</a>
          <a href={FAMILY_ROLES_URL} class="help-back">🗂 役割とできることを見る</a>
          <a href={FIRST_SETTINGS_URL} class="help-back">🌱 設定のととのえ方を見る</a>
          <a href={FAMILY_SETUP_URL} class="help-back">👪 家族のつくり方を見る</a>
          <a href={HOME_URL} class="help-back">← Tanect Home のトップへもどる</a>
        </div>
      </section>
    </div>
  </main>

  <footer class="page-foot">
    <p class="page-foot-copy">© 2026 Tanect</p>
  </footer>
</BaseLayout>

<style>
  /* ── ヘッダー（最小：ロゴのみ） ── */
  .page-head {
    border-bottom: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.9);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-md);
    font-weight: 700;
  }

  .logo-mark {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: block;
  }

  .logo-text {
    font-size: 20px;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  /* ── 本文 ── */
  .setup {
    padding: var(--space-3xl) var(--space-md);
    background: linear-gradient(180deg, var(--color-accent-soft) 0%, #ffffff 320px);
  }

  .setup-inner {
    max-width: var(--content-max);
    margin-inline: auto;
  }

  .intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .intro-title {
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: var(--lh-snug);
    color: var(--color-text);
    letter-spacing: 0.012em;
    /* 文節の途中で折らず、<wbr> を入れた位置でのみ改行する */
    word-break: keep-all;
  }

  .intro-lead {
    font-size: var(--fs-body);
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .intro-pick-note {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── ひらき方（導線） ── */
  .open {
    margin-bottom: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .open-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .open-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .open-step {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .open-cap {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text);
  }

  .open-num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
  }

  .open-figure {
    margin: 0;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .open-figure img {
    display: block;
    width: 100%;
    height: auto;
  }

  .open-ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-xl) var(--space-md);
    background: linear-gradient(148deg, #e9ebef 0%, #ffffff 100%);
    color: var(--color-text-muted);
    font-size: 13px;
    text-align: center;
  }

  .open-ph[hidden] {
    display: none;
  }

  .open-ph code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    padding: 2px 8px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 4px;
  }

  /* ── カード（共通） ── */
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  /* 単体カードはカード間の余白を確保 */
  .weekly-card,
  .ai-card {
    margin-bottom: var(--space-xl);
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .card-emoji {
    font-size: 28px;
    line-height: 1;
  }

  .card-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .card-role {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── パネル／設定の中身（スクショ＋説明） ── */
  .setting-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .shot {
    position: relative;
    width: 100%;
    max-width: 220px;
    flex-shrink: 0;
  }

  .shot-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 19;
    border-radius: 28px;
    background: linear-gradient(148deg, #1a1a2e 0%, #030213 100%);
    padding: 10px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .shot-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
  }

  .shot-ph {
    position: absolute;
    inset: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    border-radius: 20px;
    background: linear-gradient(148deg, #e9ebef 0%, #ffffff 100%);
    color: var(--color-text-muted);
    font-size: 13px;
    text-align: center;
    padding: var(--space-md);
  }

  .shot-ph[hidden] {
    display: none;
  }

  .shot-ph code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    padding: 2px 8px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 4px;
  }

  .setting-text {
    width: 100%;
  }

  .setting-lead {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .setting-points {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-left: 1.2em;
    list-style: disc;
  }

  .setting-points li {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* ── 音声で聞く（年配の方の負担軽減ハイライト） ── */
  .audio-callout {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-border-subtle);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-md);
  }

  .audio-callout-icon {
    flex-shrink: 0;
    font-size: 24px;
    line-height: 1.5;
  }

  .audio-callout-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .audio-callout-text {
    font-size: 14px;
    line-height: 1.8;
    color: var(--color-text);
  }

  .audio-callout-note {
    margin-top: var(--space-sm);
    font-size: 13px;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  /* ── 知っておくと安心なこと ── */
  .notice {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-border-subtle);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
  }

  .notice-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .notice-emoji {
    font-size: 26px;
    line-height: 1;
  }

  .notice-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .notice-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-left: 1.2em;
    list-style: disc;
  }

  .notice-list li {
    font-size: 15px;
