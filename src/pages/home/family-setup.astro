---
// 家族モニター向け「家族のつくり方」案内ページ（/family-setup）
//
// install.astro の姉妹ページ。ログイン（アカウント作成）後に、家族をどう構成するかを
// スクショ付きで案内する「身内向け」ページ。サイト全体が noindex,nofollow（BaseLayout）。
//
// 役割は2つ：
//   - まとめ役（家族を作る人）… グループ作成 → 招待コード発行 → 参加申請の承認
//   - 参加する人              … 招待コード入力 → 承認待ち → ホーム
// （出典：Tanect2 docs/spec_onboarding.md・spec_family_management.md）
//
// ⚠️ スクショ差し替え：下の screens/setup-*.png はまだ未配置。
//    画像が無いあいだは「差し替え予定」プレースホルダが表示される（onerror フォールバック）。
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const HOME_URL = import.meta.env.BASE_URL.replace(/\/$/, '') + '/home/';
const INSTALL_URL = `${base}/home/install`;
const FIRST_SETTINGS_URL = `${base}/home/first-settings`;
const RELEASE_NOTES_URL = `${base}/home/release-notes`;
const FAMILY_ROLES_URL = `${base}/home/family-roles`;

// まとめ役（家族をはじめる人）の手順
const adminSteps = [
  {
    text: '<strong>「新しく家族グループを作る」</strong> を選びます。',
    shot: 'setup-family-choice.png',
    alt: '家族グループを作るか、招待コードで参加するかを選ぶ画面',
  },
  {
    text: '<strong>家族の名前</strong>を入れます。<br />（例：「田中家」など、わかりやすい名前で大丈夫です）',
    shot: 'setup-create-name.png',
    alt: '家族グループの名前を入力する画面',
  },
  {
    text: '<strong>招待コード</strong>（6けたの英数字）が表示されます。<br />このコードを、参加してほしいご家族に LINE などで伝えてください。<br />※ コードは <strong>7日間</strong> ご利用いただけます。',
    shot: 'setup-invite-code.png',
    alt: '発行された招待コードが表示されている画面',
  },
  {
    text: 'ご家族から参加の申し込みが届いたら、<strong>家族の設定画面で「承認」</strong>します。<br />承認すると、その方が家族に加わります。',
    shot: 'setup-approve.png',
    alt: '参加申請を承認する家族設定画面',
  },
];

// 招待されて参加する人の手順
const joinSteps = [
  {
    text: 'まとめ役から受け取った <strong>招待コードを入力</strong> します。',
    shot: 'setup-enter-code.png',
    alt: '招待コードを入力する画面',
  },
  {
    text: '<strong>「承認待ち」の画面</strong>になります。<br />まとめ役の方が承認してくれるのを待ちます。',
    shot: 'setup-pending.png',
    alt: '承認待ちの画面',
  },
  {
    text: '承認されると、<strong>自動でホーム画面</strong>に進みます。<br />これで家族とつながりました。',
    shot: 'setup-home.png',
    alt: '承認後に表示されるホーム画面',
  },
];
---

<BaseLayout
  title="家族のつくり方 — Tanect Home（家族モニター）"
  description="Tanect Home でログインしたあと、家族グループを作って招待し、家族でつながるまでの手順を、スクリーンショット付きでご案内します。"
>
  <header class="page-head">
    <a href={HOME_URL} class="logo" aria-label="Tanect Home トップへ">
      <img
        class="logo-mark"
        src={`${base}/images/app-icon.png`}
        width="32"
        height="32"
        alt=""
        aria-hidden="true"
      />
      <span class="logo-text">Tanect<span class="logo-home"> Home</span></span>
    </a>
  </header>

  <main class="setup">
    <div class="setup-inner">
      <section class="intro">
        <span class="badge">🌱 家族モニターのみなさんへ</span>
        <h1 class="intro-title">家族のつくり方</h1>
        <p class="intro-lead">
          アカウントができたら、つぎは家族でつながります。<br />
          むずかしい操作はありません。下の手順どおりに進めてください。
        </p>
        <p class="intro-pick">
          家族を <strong>はじめる人がひとり</strong>。<br />
          あとのご家族は、その人から届く <strong>招待コード</strong> で参加します。<br />
          <span class="intro-pick-note">どちらの役か、下のカードで選んで進めてください。</span>
        </p>
      </section>

      <div class="cards">
        <!-- まとめ役 -->
        <section class="card" id="admin" aria-labelledby="admin-title">
          <div class="card-head">
            <span class="card-emoji" aria-hidden="true">🏠</span>
            <div>
              <h2 class="card-title" id="admin-title">家族をはじめる人</h2>
              <p class="card-role">（まとめ役）</p>
            </div>
          </div>
          <ol class="steps">
            {adminSteps.map((s, i) => (
              <li class="step">
                <div class="shot">
                  <span class="shot-num" aria-hidden="true">{i + 1}</span>
                  <div class="shot-frame">
                    <img
                      src={`${base}/screens/${s.shot}`}
                      alt={s.alt}
                      loading="lazy"
                      onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
                    />
                    <div class="shot-ph" aria-hidden="true" hidden>
                      <span>📱 スクリーンショット差し替え予定</span>
                      <code>screens/{s.shot}</code>
                    </div>
                  </div>
                </div>
                <p class="step-text" set:html={s.text} />
              </li>
            ))}
          </ol>
        </section>

        <!-- 参加する人 -->
        <section class="card" id="join" aria-labelledby="join-title">
          <div class="card-head">
            <span class="card-emoji" aria-hidden="true">📩</span>
            <div>
              <h2 class="card-title" id="join-title">招待されて参加する人</h2>
              <p class="card-role">（コードをもらった人）</p>
            </div>
          </div>
          <ol class="steps">
            {joinSteps.map((s, i) => (
              <li class="step">
                <div class="shot">
                  <span class="shot-num" aria-hidden="true">{i + 1}</span>
                  <div class="shot-frame">
                    <img
                      src={`${base}/screens/${s.shot}`}
                      alt={s.alt}
                      loading="lazy"
                      onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
                    />
                    <div class="shot-ph" aria-hidden="true" hidden>
                      <span>📱 スクリーンショット差し替え予定</span>
                      <code>screens/{s.shot}</code>
                    </div>
                  </div>
                </div>
                <p class="step-text" set:html={s.text} />
              </li>
            ))}
          </ol>
        </section>
      </div>

      <section class="roles" aria-labelledby="roles-title">
        <div class="roles-head">
          <h2 class="roles-title" id="roles-title">家族のなかの「役割」について</h2>
          <p class="roles-lead">
            家族には、3つの役割があります。<br />
            役割があると、その人だけのできることが増えます。
          </p>
        </div>
        <div class="role-cards">
          <article class="role-card">
            <span class="role-emoji" aria-hidden="true">🏠</span>
            <h3 class="role-name">まとめ役</h3>
            <p class="role-can">
              家族を招待したり、参加を承認したり。<br />
              メンバーや役割をまとめる、家族のとりまとめ役です。
            </p>
            <p class="role-count">家族に <strong>かならず1人</strong> 必要です</p>
          </article>
          <article class="role-card">
            <span class="role-emoji" aria-hidden="true">💳</span>
            <h3 class="role-name">お支払い担当</h3>
            <p class="role-can">
              アプリの利用料のお支払いや、<br />
              プランの変更を担当します。
            </p>
            <p class="role-count">家族で <strong>1人だけ</strong></p>
          </article>
          <article class="role-card">
            <span class="role-emoji" aria-hidden="true">🤝</span>
            <h3 class="role-name">サポーター</h3>
            <p class="role-can">
              親世代が「おまかせ」してくれれば、<br />
              活動を見たり、予定や設定を整えたりできます。
            </p>
            <p class="role-count"><strong>何人でも</strong> なれます</p>
          </article>
        </div>
        <p class="roles-note">
          ※ ひとりが <strong>いくつもの役割を兼ねる</strong> こともできます（例：まとめ役 兼 サポーター）。<br />
          ※ 役割を決めたり変えたりできるのは <strong>まとめ役</strong> です。家族を作った人は、はじめから「まとめ役」になっています。<br />
          ※ <strong>どの役割が何をできるか</strong>は、<a href={FAMILY_ROLES_URL}>「役割とできること」</a>でくわしくご案内しています。
        </p>
      </section>

      <section class="notice" aria-labelledby="notice-title">
        <div class="notice-head">
          <span class="notice-emoji" aria-hidden="true">💡</span>
          <h2 class="notice-title" id="notice-title">知っておくと安心なこと</h2>
        </div>
        <ul class="notice-list">
          <li>招待コードは <strong>7日間</strong> で使えなくなります。期限が切れたら、まとめ役の方があたらしいコードを出せます。</li>
          <li>家族には、いつも <strong>まとめ役がひとり</strong> 必要です。あとから別の方にまとめ役をお願いすることもできます。</li>
          <li><strong>「承認待ち」のまま</strong>進まないときは、まとめ役の方に「承認」をお願いしてみてください。</li>
        </ul>
      </section>

      <section class="help">
        <h2 class="help-title">困ったときは</h2>
        <p class="help-text">
          途中で止まってしまっても、まったく問題ありません。<br />
          画面の写真を撮って、この案内をお送りしたメール（または LINE）に返信していただければ、こちらで一緒に確認します。<br />
          インストール後は、アプリ内の画面右上の人アイコン →「お問い合わせ」からもご連絡いただけます。
        </p>
        <div class="help-links">
          <a href={FIRST_SETTINGS_URL} class="help-back">⚙️ つながったあとの設定のととのえ方を見る</a>
          <a href={INSTALL_URL} class="help-back">📲 インストール方法のご案内を見る</a>
          <a href={RELEASE_NOTES_URL} class="help-back">📓 最新の更新内容（リリースノート）を見る</a>
          <a href={HOME_URL} class="help-back">← Tanect Home のトップへもどる</a>
        </div>
      </section>
    </div>
  </main>

  <footer class="page-foot">
    <p class="page-foot-copy">© 2026 Tanect</p>
  </footer>
</BaseLayout>

<style>
  /* ── ヘッダー（最小：ロゴのみ） ── */
  .page-head {
    border-bottom: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.9);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-md);
    font-weight: 700;
  }

  .logo-mark {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: block;
  }

  .logo-text {
    font-size: 20px;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  /* ── 本文 ── */
  .setup {
    padding: var(--space-3xl) var(--space-md);
    background: linear-gradient(180deg, var(--color-accent-soft) 0%, #ffffff 320px);
  }

  .setup-inner {
    max-width: var(--content-max);
    margin-inline: auto;
  }

  .intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .intro-title {
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: var(--lh-snug);
    color: var(--color-text);
    letter-spacing: 0.012em;
  }

  .intro-lead {
    font-size: var(--fs-body);
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .intro-pick {
    margin-top: var(--space-sm);
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--color-text);
  }

  .intro-pick-note {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── 役割カード ── */
  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .card-emoji {
    font-size: 28px;
    line-height: 1;
  }

  .card-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .card-role {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── ステップ（スクショ付き） ── */
  .steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .shot {
    position: relative;
    width: 100%;
    max-width: 220px;
  }

  .shot-num {
    position: absolute;
    top: -10px;
    left: -10px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    color: var(--color-accent-text);
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    box-shadow: 0 2px 6px rgba(252, 163, 81, 0.4);
  }

  .shot-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 19;
    border-radius: 28px;
    background: linear-gradient(148deg, #1a1a2e 0%, #030213 100%);
    padding: 10px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .shot-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
  }

  .shot-ph {
    position: absolute;
    inset: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    border-radius: 20px;
    background: linear-gradient(148deg, #e9ebef 0%, #ffffff 100%);
    color: var(--color-text-muted);
    font-size: 13px;
    text-align: center;
    padding: var(--space-md);
  }

  .shot-ph[hidden] {
    display: none;
  }

  .shot-ph code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    padding: 2px 8px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 4px;
  }

  .step-text {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* ── 役割の説明 ── */
  .roles {
    margin-top: var(--space-3xl);
  }

  .roles-head {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .roles-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .roles-lead {
    font-size: var(--fs-body);
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .role-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .role-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xl);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-align: center;
  }

  .role-emoji {
    font-size: 36px;
    line-height: 1;
  }

  .role-name {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .role-can {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .role-count {
    margin-top: auto;
    padding: 4px 14px;
    background: var(--color-accent-soft);
    border-radius: var(--radius-pill);
    font-size: var(--fs-small);
    color: var(--color-accent-ink);
  }

  .roles-note {
    margin-top: var(--space-lg);
    font-size: var(--fs-small);
    line-height: 1.8;
    color: var(--color-text-muted);
    text-align: center;
  }

  .roles-note a {
    color: var(--color-accent-ink);
    text-decoration: underline;
  }

  /* ── 知っておくと安心なこと ── */
  .notice {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-border-subtle);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
  }

  .notice-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .notice-emoji {
    font-size: 26px;
    line-height: 1;
  }

  .notice-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .notice-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-left: 1.2em;
    list-style: disc;
  }

  .notice-list li {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* ── 困ったときは ── */
  .help {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-bg-soft);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .help-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .help-text {
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .help-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
    justify-content: center;
    margin-top: var(--space-lg);
  }

  .help-back {
    display: inline-block;
    font-size: 14px;
    color: var(--color-accent-ink);
    text-decoration: underline;
  }

  /* ── フッター ── */
  .page-foot {
    padding: var(--space-xl) var(--space-md);
    text-align: center;
    border-top: 1px solid var(--color-border-subtle);
  }

  .page-foot-copy {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── Tablet and up ── */
  @media (min-width: 768px) {
    .intro-title {
      font-size: var(--fs-h1-lg);
    }

    /* カード内のステップを横並び（スクショギャラリー） */
    .steps {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2xl) var(--space-xl);
    }

    /* 役割カードを3カラム */
    .role-cards {
      grid-template-columns: repeat(3, 1fr);
      align-items: stretch;
    }
  }
</style>
