---
// 家族モニター向け インストール案内ページ（/install）
//
// 公開LPのナビからはリンクしない「身内向け」ページ。
// 第一波モニターには、申し込み後の返信メール／LINE でこのページのURLを送る。
// サイト全体が noindex,nofollow（BaseLayout）なので検索には載らない。
//
// ⚠️ 差し替え必須：下の2つのリンクを、発行済みの実URLに書き換えてください。
//   - ANDROID_INVITE_LINK … Firebase App Distribution の monitors グループ「招待リンク」
//   - IOS_TESTFLIGHT_LINK  … App Store Connect → TestFlight 外部テストの「公開リンク」（Beta Review 承認後）
// （手順の出典：tanect-management/04_customers/monitor_onboarding.md §1・§3）
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUPPORT_EMAIL } from '../../config';

// Step1: テスターとしての追加登録（招待リンク）
const ANDROID_INVITE_LINK = 'https://appdistribution.firebase.dev/i/e839ccc26eed5ed4';
// Step2: App Tester アプリのインストール（配布アプリのページ）
const ANDROID_APP_TESTER_LINK = 'https://appdistribution.firebase.google.com/testerapps/1:327542930366:android:7b5bde13423dc28fcd57ef/releases/07cu2l78drfag?utm_source=firebase-console';
const IOS_TESTFLIGHT_LINK = 'https://testflight.apple.com/join/1hjBMcpE';
// コネクティル様経由のモニター向け TestFlight 公開リンク（一般とグループを分けて配布）
const IOS_TESTFLIGHT_LINK_CONNECTIL = 'https://testflight.apple.com/join/8aYDSyHK';

// リンクが未発行のうちは true にしておくと、ボタンを「準備中」表示にできる
const ANDROID_READY = true;
const IOS_READY = true;

const HOME_URL = import.meta.env.BASE_URL.replace(/\/$/, '') + '/home/';
const RELEASE_NOTES_URL = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/home/release-notes`;
const FAMILY_SETUP_URL = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/home/family-setup`;

const androidSteps = [
  'このページを <strong>Androidスマホ</strong> で開き、まず下の <strong>「① 登録ページを開く」</strong> ボタンを押します。',
  '<strong>Googleアカウント</strong>でサインインし、利用規約に同意します（テスター登録）。',
  '次に <strong>「② Androidでアプリを入れる」</strong> ボタンを押し、画面の案内に従って <strong>「App Tester」アプリ</strong> をインストールします。',
  'App Tester の中から <strong>Tanect Home</strong> をインストールします。<br />※「提供元不明のアプリ」の確認が出たら、画面の案内に従って許可してください（アプリストア以外からのお届けのためです）。',
  '次の新しいバージョンが出ると、App Tester からお知らせが届きます。',
];

// iPhone の手順（スクショ付き）
// ⚠️ スクショ配置：public/screens/ に下の4枚を置いてください（未配置の間はプレースホルダー表示）
const iosSteps = [
  {
    text: 'このページを <strong>iPhone</strong> で開き、下の <strong>「iPhoneでアプリを入れる」</strong> ボタンを押します。TestFlight の案内ページが開きます。',
    shot: 'ios-install-1-testflight-page.png',
    alt: 'TestFlightの案内ページ。「TestFlightを入手する」と「App Storeで表示する」ボタンが表示されている',
  },
  {
    text: '<strong>「App Storeで表示する」</strong>を押し、App Store で <strong>TestFlight アプリ</strong> を入れます。<br /><span class="step-sub">※ すでに TestFlight が入っている方は、この手順はとばして大丈夫です。</span>',
    shot: 'ios-install-2-appstore.png',
    alt: 'App StoreのTestFlightのページ。入手中の表示',
  },
  {
    text: 'TestFlight を開くと「ようこそTestFlightへ」の画面が出ます。いちばん下の <strong>「続ける」</strong> を押します。',
    shot: 'ios-install-3-welcome.png',
    alt: 'TestFlightのようこそ画面。下部に「続ける」ボタン',
  },
  {
    text: '<strong>TanectHome</strong> の横の <strong>「インストール」</strong> を押します。これでおしまいです！<br /><span class="step-sub">※ TanectHome が見当たらないときは、もう一度このページに戻って下のボタンを押してください。</span>',
    shot: 'ios-install-4-tanecthome.png',
    alt: 'TestFlightのアプリ一覧。TanectHomeの横にインストールボタン',
  },
];
---

<BaseLayout
  title="インストール方法 — Tanect Home（家族モニター）"
  description="Tanect Home 家族モニターのみなさん向けの、iPhone・Android それぞれのインストール手順のご案内です。"
>
  <header class="page-head">
    <a href={HOME_URL} class="logo" aria-label="Tanect Home トップへ">
      <img
        class="logo-mark"
        src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/images/app-icon.png`}
        width="32"
        height="32"
        alt=""
        aria-hidden="true"
      />
      <span class="logo-text">Tanect<span class="logo-home"> Home</span></span>
    </a>
  </header>

  <main class="install">
    <div class="install-inner">
      <section class="intro">
        <span class="badge">🌱 家族モニターのみなさんへ</span>
        <h1 class="intro-title">インストール方法のご案内</h1>
        <p class="intro-lead">
          Tanect Home を試してくださり、ありがとうございます。<br />
          お使いのスマホにあわせて、下の手順どおりに進めてください。<br />
          むずかしい設定はありません。途中でつまずいても大丈夫です。
        </p>
        <p class="intro-pick">
          お使いの端末は <strong>iPhone</strong> ですか？ <strong>Android</strong> ですか？<br />
          <span class="intro-pick-note">わからないときは、メールでお問い合わせください。</span>
        </p>
      </section>

      <div class="cards">
        <!-- iPhone -->
        <section class="card" id="iphone" aria-labelledby="iphone-title">
          <div class="card-head">
            <span class="card-emoji" aria-hidden="true">🍎</span>
            <h2 class="card-title" id="iphone-title">iPhone をお使いの方</h2>
          </div>
          <ol class="steps steps-shots">
            {iosSteps.map((s, i) => (
              <li class="step step-shot">
                <div class="shot">
                  <span class="shot-num" aria-hidden="true">{i + 1}</span>
                  <div class="shot-frame">
                    <img
                      src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/screens/${s.shot}`}
                      alt={s.alt}
                      loading="lazy"
                      onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
                    />
                    <div class="shot-ph" aria-hidden="true" hidden>
                      <span>📱 スクリーンショット差し替え予定</span>
                      <code>screens/{s.shot}</code>
                    </div>
                  </div>
                </div>
                <p class="step-text step-text-center" set:html={s.text} />
              </li>
            ))}
          </ol>
          <div class="card-cta">
            {IOS_READY ? (
              <div class="btn-steps">
                <a
                  href={IOS_TESTFLIGHT_LINK}
                  class="btn btn-accent"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  iPhoneでアプリを入れる<br />（一般の方向け）
                </a>
                <a
                  href={IOS_TESTFLIGHT_LINK_CONNECTIL}
                  class="btn btn-accent"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  iPhoneでアプリを入れる<br />（コネクティル様向け）
                </a>
              </div>
            ) : (
              <span class="btn btn-disabled" aria-disabled="true">準備中（リンクは個別にお送りします）</span>
            )}
            <p class="card-note">※ 次の新しいバージョンが出ると、TestFlight からお知らせが届きます。<br />※ うまくいかないときは、メールでお問い合わせください。</p>
            <a href={`mailto:${SUPPORT_EMAIL}`} class="btn btn-primary">メールを送る（{SUPPORT_EMAIL}）</a>
          </div>
        </section>

        <!-- Android -->
        <section class="card" id="android" aria-labelledby="android-title">
          <div class="card-head">
            <span class="card-emoji" aria-hidden="true">🤖</span>
            <h2 class="card-title" id="android-title">Android をお使いの方</h2>
          </div>
          <ol class="steps">
            {androidSteps.map((s, i) => (
              <li class="step">
                <span class="step-num" aria-hidden="true">{i + 1}</span>
                <span class="step-text" set:html={s} />
              </li>
            ))}
          </ol>
          <div class="card-cta">
            {ANDROID_READY ? (
              <div class="btn-steps">
                <a
                  href={ANDROID_INVITE_LINK}
                  class="btn btn-accent"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  ① 登録ページを開く
                </a>
                <a
                  href={ANDROID_APP_TESTER_LINK}
                  class="btn btn-accent"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  ② Androidでアプリを入れる
                </a>
              </div>
            ) : (
              <span class="btn btn-disabled" aria-disabled="true">準備中（リンクは個別にお送りします）</span>
            )}
            <p class="card-note">※ かならず <strong>①→②</strong> の順に進めてください。<br />※ うまくいかないときは、メールでお問い合わせください。</p>
            <a href={`mailto:${SUPPORT_EMAIL}`} class="btn btn-primary">メールを送る（{SUPPORT_EMAIL}）</a>
          </div>
        </section>
      </div>

      <section class="notice" aria-labelledby="notice-title">
        <div class="notice-head">
          <span class="notice-emoji" aria-hidden="true">✉️</span>
          <h2 class="notice-title" id="notice-title">アプリを開いてアカウントを作るとき</h2>
        </div>
        <p class="notice-text">
          インストールが終わってアプリを開くと、はじめにアカウントを作ります。<br />
          そのとき、確認のための <strong>6けたの数字（コード）</strong> がメールで届きます。<br />
          このコードを入力すると、登録が完了します。
        </p>
        <p class="notice-text">
          メールの件名は <strong>「【Tanect Home】確認コード：（数字）」</strong> です。<br />
          差出人は自動送信用の英数字のアドレスになっています。<br />
          <strong>迷惑メール・プロモーションのフォルダ</strong>に入ってしまうことがあるので、受信トレイに見当たらないときは、そちらものぞいてみてください。
        </p>
        <p class="notice-note">※ コードは、届いてから <strong>10分のあいだ</strong> ご利用いただけます。見つからないときや時間が過ぎたときは、登録の画面からもう一度お送りできます。</p>
        <p class="notice-note">※ それでも届かないときは、メールでお問い合わせください。</p>
      </section>

      <section class="help">
        <h2 class="help-title">困ったときは</h2>
        <p class="help-text">
          途中で止まってしまっても、まったく問題ありません。<br />
          画面の写真を撮って、メールでお送りいただければ、こちらで一緒に確認します。<br />
          インストール後は、アプリ内の画面右上の人アイコン →「お問い合わせ」からもご連絡いただけます。
        </p>
        <p class="help-mail">
          <a href={`mailto:${SUPPORT_EMAIL}`} class="btn btn-primary">メールを送る（{SUPPORT_EMAIL}）</a>
        </p>
        <div class="help-links">
          <a href={FAMILY_SETUP_URL} class="help-back">👪 アプリを開いたら（家族のつくり方）を見る</a>
          <a href={RELEASE_NOTES_URL} class="help-back">📓 最新の更新内容（リリースノート）を見る</a>
          <a href={HOME_URL} class="help-back">← Tanect Home のトップへもどる</a>
        </div>
      </section>
    </div>
  </main>

  <footer class="page-foot">
    <p class="page-foot-copy">© 2026 Tanect</p>
  </footer>
</BaseLayout>

<style>
  /* ── ヘッダー（最小：ロゴのみ） ── */
  .page-head {
    border-bottom: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.9);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-md);
    font-weight: 700;
  }

  .logo-mark {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: block;
  }

  .logo-text {
    font-size: 20px;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  /* ── 本文 ── */
  .install {
    padding: var(--space-3xl) var(--space-md);
    background: linear-gradient(180deg, var(--color-accent-soft) 0%, #ffffff 320px);
  }

  .install-inner {
    max-width: var(--content-max);
    margin-inline: auto;
  }

  .intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .intro-title {
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: var(--lh-snug);
    color: var(--color-text);
    letter-spacing: 0.012em;
  }

  .intro-lead {
    font-size: var(--fs-body);
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .intro-pick {
    margin-top: var(--space-sm);
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--color-text);
  }

  .intro-pick-note {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── 端末カード ── */
  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .card-emoji {
    font-size: 28px;
    line-height: 1;
  }

  .card-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .step-num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    color: var(--color-accent-text);
    font-size: 15px;
    font-weight: 700;
    line-height: 1;
  }

  .step-text {
    font-size: 16px;
    line-height: 1.8;
    color: var(--color-text);
    padding-top: 2px;
  }

  .step-sub {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── スクショ付きステップ（iPhone） ── */
  .steps-shots {
    gap: var(--space-xl);
  }

  .step-shot {
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .step-text-center {
    text-align: center;
    font-size: 15px;
    padding-top: 0;
  }

  .shot {
    position: relative;
    width: 100%;
    max-width: 220px;
  }

  .shot-num {
    position: absolute;
    top: -10px;
    left: -10px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    color: var(--color-accent-text);
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    box-shadow: 0 2px 6px rgba(252, 163, 81, 0.4);
  }

  .shot-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 19;
    border-radius: 28px;
    background: linear-gradient(148deg, #1a1a2e 0%, #030213 100%);
    padding: 10px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .shot-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
  }

  .shot-ph {
    position: absolute;
    inset: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    border-radius: 20px;
    background: linear-gradient(148deg, #e9ebef 0%, #ffffff 100%);
    color: var(--color-text-muted);
    font-size: 13px;
    text-align: center;
    padding: var(--space-md);
  }

  .shot-ph[hidden] {
    display: none;
  }

  .shot-ph code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    padding: 2px 8px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 4px;
  }

  .card-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .card-cta .btn {
    width: 100%;
    max-width: 360px;
  }

  .btn-steps {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    width: 100%;
  }

  /* <br> 入りの2行ラベルは flex だと中央に揃わないため、ブロック＋中央揃えにする */
  .btn-steps .btn {
    display: block;
    text-align: center;
  }

  .btn-disabled {
    background: var(--color-badge-bg);
    color: var(--color-text-muted);
    cursor: not-allowed;
    font-size: var(--fs-small);
  }

  .btn-disabled:hover {
    transform: none;
    box-shadow: none;
  }

  .card-note {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    text-align: center;
  }

  /* ── 確認メールの注意 ── */
  .notice {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-border-subtle);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
  }

  .notice-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .notice-emoji {
    font-size: 26px;
    line-height: 1;
  }

  .notice-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .notice-text {
    font-size: 16px;
    line-height: 1.9;
    color: var(--color-text);
  }

  .notice-text + .notice-text {
    margin-top: var(--space-md);
  }

  .notice-note {
    margin-top: var(--space-md);
    font-size: var(--fs-small);
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  /* ── 困ったときは ── */
  .help {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-bg-soft);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .help-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .help-text {
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .help-mail {
    margin-top: var(--space-lg);
  }

  .help-mail .btn {
    width: 100%;
    max-width: 360px;
  }

  .help-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
    justify-content: center;
    margin-top: var(--space-lg);
  }

  .help-back {
    display: inline-block;
    font-size: 14px;
    color: var(--color-accent-ink);
    text-decoration: underline;
  }

  /* ── フッター ── */
  .page-foot {
    padding: var(--space-xl) var(--space-md);
    text-align: center;
    border-top: 1px solid var(--color-border-subtle);
  }

  .page-foot-copy {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── Tablet and up ── */
  @media (min-width: 768px) {
    .intro-title {
      font-size: var(--fs-h1-lg);
    }

    .cards {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }
</style>
