---
// 家族モニター向け「設定のととのえ方」案内ページ（/first-settings）
//
// install.astro → family-setup.astro と続く身内向けページ群の3枚目。
// アプリを入れて家族でつながったあと、お好みに合わせて整えておくと安心な設定を
// スクショ付きで案内する。サイト全体が noindex,nofollow（BaseLayout）。
//
// 掲載する設定（ユーザー確定）：表示まわり／便利機能／家族・見守り／家族ごとの背景画像。
// （通知まわりは今回は載せない。出典：Tanect2 PersonalSettings.razor・FamilySettings.razor）
//
// ⚠️ スクショ差し替え：下の screens/settings-*.png はまだ未配置。
//    画像が無いあいだは「差し替え予定」プレースホルダが表示される（onerror フォールバック）。
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const HOME_URL = import.meta.env.BASE_URL.replace(/\/$/, '') + '/home/';
const INSTALL_URL = `${base}/home/install`;
const FAMILY_SETUP_URL = `${base}/home/family-setup`;
const SUPPORT_PARENT_URL = `${base}/home/support-parent`;
const RELEASE_NOTES_URL = `${base}/home/release-notes`;

// お好みに合わせて整える設定（カード）
const settingGroups = [
  {
    emoji: '🔠',
    title: '表示まわり',
    where: '人アイコン →「個人設定」',
    shot: 'settings-display.png',
    alt: '個人設定の表示まわり（お名前・文字サイズ・やさしい操作モード）の画面',
    lead: 'まず、ご自身が使いやすい見た目にととのえます。',
    points: [
      '<strong>お名前</strong> … 家族に表示されるお名前です。「変更」を押すと保存されます。',
      '<strong>文字サイズ</strong> … <strong>標準 / 大 / 特大</strong> から選べます。見えにくいときは大きくしてください。',
      '<strong>やさしい操作モード</strong> … ONにすると画面がシンプルになり、操作で迷いにくくなります。下のメニューバーから「予定」が消え、<strong>「私の」「みんなの」「知る」</strong>の3つになります。予定は、<strong>サポーター</strong>の方が代わりに入力できます（サポーターへのおまかせが必要です）。',
    ],
  },
  {
    emoji: '🌤',
    title: '便利機能',
    where: '人アイコン →「個人設定」',
    shot: 'settings-convenience.png',
    alt: '個人設定の便利機能（お天気の位置情報・位置情報機能）の画面',
    lead: '毎日をちょっと便利にする設定です。',
    points: [
      '<strong>お天気の位置情報</strong> …「現在地を使う」を押すと、お住まいの地域の天気が表示されます。',
      '<strong>位置情報機能</strong> … 必要なときだけONにできます。気になる方はOFFのままでも大丈夫です。',
    ],
  },
  {
    emoji: '🤝',
    title: '家族・見守り',
    where: '人アイコン →「個人設定 / 家族設定」',
    shot: 'delegate-omakase.png',
    alt: '設定／分析をサポーターにおまかせのON/OFF（親世代の個人設定 → その他）の画面',
    lead: '家族で支え合うための設定です。',
    points: [
      '<strong>サポーターへのおまかせ</strong>（親世代の「個人設定 → その他」）… 「設定／分析をサポーターにおまかせ」をONにすると、サポーター（お子さんなど）が代わりに予定や設定をととのえたり、暮らしのまとめを見守れます。',
      '<strong>役割の設定</strong>（家族設定）… まとめ役が、お支払い担当・サポーター・まとめ役などの役割を決められます。<strong>まとめ役は2人以上がおすすめ</strong>です（何かあったときも安心）。',
    ],
  },
  {
    emoji: '🖼',
    title: '家族の背景画像',
    where: '人アイコン →「家族設定」',
    shot: 'settings-background.png',
    alt: '家族設定で背景画像をアップロードする画面',
    lead: '家族ごとに、ホーム画面の背景を設定できます。',
    points: [
      '家族設定の「<strong>画像をアップロード</strong>」から、お気に入りの写真を背景にできます（最大2MB）。',
      '家族みんなで見る画面が、ぐっと「わが家らしく」なります。背景画像は家族の<strong>どなたでも</strong>設定できます。',
    ],
  },
];
---

<BaseLayout
  title="設定のととのえ方 — Tanect Home（家族モニター）"
  description="アプリを入れて家族でつながったあと、お好みに合わせて整えておくと安心な設定を、スクリーンショット付きでご案内します。"
>
  <header class="page-head">
    <a href={HOME_URL} class="logo" aria-label="Tanect Home トップへ">
      <img
        class="logo-mark"
        src={`${base}/images/app-icon.png`}
        width="32"
        height="32"
        alt=""
        aria-hidden="true"
      />
      <span class="logo-text">Tanect<span class="logo-home"> Home</span></span>
    </a>
  </header>

  <main class="setup">
    <div class="setup-inner">
      <section class="intro">
        <span class="badge">🌱 家族モニターのみなさんへ</span>
        <h1 class="intro-title">設定のととのえ方</h1>
        <p class="intro-lead">
          アプリを入れて、家族でつながったら、つぎは仕上げです。<br />
          お好みに合わせて整えておくと、もっと使いやすくなります。
        </p>
        <p class="intro-pick">
          ぜんぶ設定しなくても大丈夫。<br />
          <span class="intro-pick-note">気になるところから、少しずつで構いません。設定はあとからいつでも変えられます。</span>
        </p>
      </section>

      <!-- 設定の開き方 -->
      <section class="card open-card" aria-labelledby="open-title">
        <div class="card-head">
          <span class="card-emoji" aria-hidden="true">⚙️</span>
          <div>
            <h2 class="card-title" id="open-title">設定の開き方</h2>
            <p class="card-role">まずはここから</p>
          </div>
        </div>
        <div class="setting-body">
          <div class="shot">
            <div class="shot-frame">
              <img
                src={`${base}/screens/settings-menu.png`}
                alt="画面右上の人アイコンから設定メニューを開く画面"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
              />
              <div class="shot-ph" aria-hidden="true" hidden>
                <span>📱 スクリーンショット差し替え予定</span>
                <code>screens/settings-menu.png</code>
              </div>
            </div>
          </div>
          <div class="setting-text">
            <p class="setting-lead">
              アプリの画面 <strong>右上の人アイコン</strong> をタップすると、設定メニューがひらきます。
            </p>
            <ul class="setting-points">
              <li><strong>個人設定</strong> … ご自身の見た目・お名前などをととのえます。</li>
              <li><strong>家族設定</strong> … 家族の背景画像（どなたでも）や、名前・役割（まとめ役）などをととのえます。</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- 整えると安心な設定 -->
      <div class="cards settings-cards">
        {settingGroups.map((g) => (
          <section class="card setting-card">
            <div class="card-head">
              <span class="card-emoji" aria-hidden="true">{g.emoji}</span>
              <div>
                <h2 class="card-title">{g.title}</h2>
                <p class="card-role">{g.where}</p>
              </div>
            </div>
            <div class="setting-body">
              <div class="shot">
                <div class="shot-frame">
                  <img
                    src={`${base}/screens/${g.shot}`}
                    alt={g.alt}
                    loading="lazy"
                    onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
                  />
                  <div class="shot-ph" aria-hidden="true" hidden>
                    <span>📱 スクリーンショット差し替え予定</span>
                    <code>screens/{g.shot}</code>
                  </div>
                </div>
              </div>
              <div class="setting-text">
                <p class="setting-lead">{g.lead}</p>
                <ul class="setting-points">
                  {g.points.map((p) => (
                    <li set:html={p} />
                  ))}
                </ul>
              </div>
            </div>
          </section>
        ))}
      </div>

      <section class="notice" aria-labelledby="notice-title">
        <div class="notice-head">
          <span class="notice-emoji" aria-hidden="true">💡</span>
          <h2 class="notice-title" id="notice-title">知っておくと安心なこと</h2>
        </div>
        <ul class="notice-list">
          <li>設定は <strong>あとからいつでも</strong> 変えられます。まずは気になるところだけで大丈夫です。</li>
          <li><strong>やさしい操作モード</strong> は、いつでも元に戻せます。気軽に試してみてください。</li>
          <li>見えかたや操作で困ったら、画面右上の人アイコン →「お問い合わせ」からご連絡いただけます。</li>
        </ul>
      </section>

      <section class="help">
        <h2 class="help-title">困ったときは</h2>
        <p class="help-text">
          設定がうまくいかなくても、まったく問題ありません。<br />
          画面の写真を撮って、この案内をお送りしたメール（または LINE）に返信していただければ、こちらで一緒に確認します。<br />
          アプリ内の画面右上の人アイコン →「お問い合わせ」からもご連絡いただけます。
        </p>
        <div class="help-links">
          <a href={FAMILY_SETUP_URL} class="help-back">👪 家族のつくり方をもう一度見る</a>
          <a href={SUPPORT_PARENT_URL} class="help-back">🤝 離れた親をサポートする方法を見る</a>
          <a href={INSTALL_URL} class="help-back">📲 インストール方法のご案内を見る</a>
          <a href={RELEASE_NOTES_URL} class="help-back">📓 最新の更新内容（リリースノート）を見る</a>
          <a href={HOME_URL} class="help-back">← Tanect Home のトップへもどる</a>
        </div>
      </section>
    </div>
  </main>

  <footer class="page-foot">
    <p class="page-foot-copy">© 2026 Tanect</p>
  </footer>
</BaseLayout>

<style>
  /* ── ヘッダー（最小：ロゴのみ） ── */
  .page-head {
    border-bottom: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.9);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-md);
    font-weight: 700;
  }

  .logo-mark {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: block;
  }

  .logo-text {
    font-size: 20px;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  /* ── 本文 ── */
  .setup {
    padding: var(--space-3xl) var(--space-md);
    background: linear-gradient(180deg, var(--color-accent-soft) 0%, #ffffff 320px);
  }

  .setup-inner {
    max-width: var(--content-max);
    margin-inline: auto;
  }

  .intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .intro-title {
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: var(--lh-snug);
    color: var(--color-text);
    letter-spacing: 0.012em;
  }

  .intro-lead {
    font-size: var(--fs-body);
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .intro-pick {
    margin-top: var(--space-sm);
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--color-text);
  }

  .intro-pick-note {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── カード ── */
  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  /* 「設定の開き方」カードは設定カード群の上に少し間をあけて置く */
  .open-card {
    margin-bottom: var(--space-xl);
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .card-emoji {
    font-size: 28px;
    line-height: 1;
  }

  .card-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .card-role {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── 設定の中身（スクショ＋説明） ── */
  .setting-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .shot {
    position: relative;
    width: 100%;
    max-width: 220px;
    flex-shrink: 0;
  }

  .shot-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 19;
    border-radius: 28px;
    background: linear-gradient(148deg, #1a1a2e 0%, #030213 100%);
    padding: 10px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .shot-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
  }

  .shot-ph {
    position: absolute;
    inset: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    border-radius: 20px;
    background: linear-gradient(148deg, #e9ebef 0%, #ffffff 100%);
    color: var(--color-text-muted);
    font-size: 13px;
    text-align: center;
    padding: var(--space-md);
  }

  .shot-ph[hidden] {
    display: none;
  }

  .shot-ph code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    padding: 2px 8px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 4px;
  }

  .setting-text {
    width: 100%;
  }

  .setting-lead {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .setting-points {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-left: 1.2em;
    list-style: disc;
  }

  .setting-points li {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* ── 知っておくと安心なこと ── */
  .notice {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-border-subtle);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
  }

  .notice-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .notice-emoji {
    font-size: 26px;
    line-height: 1;
  }

  .notice-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
  }

  .notice-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-left: 1.2em;
    list-style: disc;
  }

  .notice-list li {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* ── 困ったときは ── */
  .help {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background: var(--color-bg-soft);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .help-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .help-text {
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .help-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
    justify-content: center;
    margin-top: var(--space-lg);
  }

  .help-back {
    display: inline-block;
    font-size: 14px;
    color: var(--color-accent-ink);
    text-decoration: underline;
  }

  /* ── フッター ── */
  .page-foot {
    padding: var(--space-xl) var(--space-md);
    text-align: center;
    border-top: 1px solid var(--color-border-subtle);
  }

  .page-foot-copy {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* ── Tablet and up ── */
  @media (min-width: 768px) {
    .intro-title {
      font-size: var(--fs-h1-lg);
    }

    /* スクショと説明を横並びに */
    .setting-body {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-2xl);
    }

    .setting-text {
      flex: 1;
    }
  }
</style>
