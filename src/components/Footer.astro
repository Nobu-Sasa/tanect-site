---
// 共通フッター — コーポレート・LP（/home/ 配下）の全ページで使用。
// 法務リンク（会社概要・プライバシーポリシー・お問い合わせ）をここに集約する。
import TanectMark from './TanectMark.astro';

const year = 2026;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

type NavLink = {
  href: string;
  label: string;
};

const serviceLinks: NavLink[] = [
  { href: `${base}/home/`, label: 'Tanect Home（家族をつなぐアプリ）' },
  { href: `${base}/dev-support`, label: 'システム開発支援' },
];

const companyLinks: NavLink[] = [
  { href: `${base}/about`, label: 'タネクトについて' },
  { href: `${base}/company`, label: '会社概要' },
  { href: `${base}/privacy`, label: 'プライバシーポリシー' },
  // 特商法表記（/tokushoho）は住所確定・有料化前に公開したらここへ追加する
  { href: `${base}/contact`, label: 'お問い合わせ' },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href={import.meta.env.BASE_URL} class="footer-logo" aria-label="タネクト（Tanect）トップへ">
        <span class="footer-logo-mark">
          <TanectMark size={28} />
        </span>
        <span class="footer-logo-text">Tanect</span>
      </a>
      <p class="footer-tagline">
        タネクト = 種 × コネクト。<br />
        奈良と東京の二拠点から、システム・サービスの開発と開発支援を。
      </p>
    </div>

    <nav class="footer-nav" aria-label="サービス">
      <p class="footer-nav-title">サービス</p>
      {serviceLinks.map((link) => (
        <a href={link.href} class="footer-link">{link.label}</a>
      ))}
    </nav>

    <nav class="footer-nav" aria-label="運営情報">
      <p class="footer-nav-title">運営情報</p>
      {companyLinks.map((link) => (
        <a href={link.href} class="footer-link">{link.label}</a>
      ))}
    </nav>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">© {year} Tanect</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: #ffffff;
    padding: var(--space-2xl) 0 var(--space-lg);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-weight: 700;
    margin-bottom: var(--space-md);
  }

  .footer-logo-mark {
    display: inline-flex;
    color: #ffffff; /* マーク色は暫定（色は別途相談中） */
  }

  .footer-logo-text {
    font-size: 20px;
    letter-spacing: -0.01em;
  }

  .footer-tagline {
    font-size: var(--fs-small);
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.7);
    max-width: 360px;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-nav-title {
    font-size: var(--fs-small);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-xs);
  }

  .footer-link {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-link:hover {
    color: #ffffff;
  }

  .footer-bottom {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-lg) var(--space-md) 0;
    margin-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer-copy {
    font-size: var(--fs-small);
    color: rgba(255, 255, 255, 0.6);
  }

  /* Tablet and up */
  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }
</style>
