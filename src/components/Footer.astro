---
// フッター — ロゴ・ナビ・コピーライト
const year = 2026;

type NavLink = {
  href: string;
  label: string;
  external?: boolean;
};

const navLinks: NavLink[] = [
  { href: '#use-case', label: '使い方' },
  { href: '#features', label: '機能' },
  { href: '#faq', label: 'よくある質問' },
  { href: '#pricing', label: '料金' },
  { href: '#monitor', label: '家族モニター募集' },
  { href: 'https://nobu-sasa.github.io/tanect-privacy/', label: 'プライバシーポリシー', external: true },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href={import.meta.env.BASE_URL} class="footer-logo" aria-label="Tanect Home">
        <img
          class="footer-logo-mark"
          src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/images/app-icon.png`}
          width="30"
          height="30"
          alt=""
          aria-hidden="true"
        />
        <span class="footer-logo-text">Tanect</span>
      </a>
      <p class="footer-tagline">
        奈良からはじまる、家族のつながり。<br />
        日々のあゆみを、家族とそっとつなぐアプリ。
      </p>
    </div>

    <nav class="footer-nav" aria-label="フッターナビゲーション">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="footer-link"
          {...(link.external === true ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >{link.label}</a>
      ))}
    </nav>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">© {year} Tanect Home</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: #ffffff;
    padding: var(--space-2xl) 0 var(--space-lg);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-weight: 700;
    margin-bottom: var(--space-md);
  }

  .footer-logo-mark {
    width: 30px;
    height: 30px;
    border-radius: 7px;
    display: block;
  }

  .footer-logo-text {
    font-size: 20px;
    letter-spacing: -0.01em;
  }

  .footer-tagline {
    font-size: var(--fs-small);
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.7);
    max-width: 360px;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-xl);
  }

  .footer-link {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-link:hover {
    color: #ffffff;
  }

  .footer-bottom {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-lg) var(--space-md) 0;
    margin-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer-copy {
    font-size: var(--fs-small);
    color: rgba(255, 255, 255, 0.6);
  }

  /* Tablet and up */
  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }
</style>
