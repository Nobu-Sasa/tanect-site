---
// Tanect Hero — Based on Mindful Figma template, adapted for Tanect brand.
// Japanese copy. Hero image rotates through the Nara landscape and four seasons.
import IconHome from './icons/IconHome.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const heroImages = [
  { src: `${base}/images/hero-nara.png`, alt: '奈良の山並みと木漏れ日。Tanect Home が生まれた土地の風景。' },
  { src: `${base}/images/hero-nara-spring.png`, alt: '奈良の春。桜並木の道を歩く犬。' },
  { src: `${base}/images/hero-nara-summer.png`, alt: '奈良の夏。畑で実るゴーヤと青々とした葉。' },
  { src: `${base}/images/hero-nara-autumn.png`, alt: '奈良の秋。紅葉と石灯籠のある庭。' },
  { src: `${base}/images/hero-nara-winter.png`, alt: '奈良の冬。雪をまとった山と冬空。' },
];
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy">
      <span class="badge">🌿 家族のあゆみを、やさしくつなぐ</span>

      <h1 class="hero-title">
        <span class="hero-title-line">日々のあゆみを、</span>
        <span class="hero-title-line hero-title-emphasis">家族とそっとつなぐ。</span>
      </h1>

      <p class="hero-lead">
        Tanect Home は、離れて暮らすご家族と、日々のあゆみをそっと共有するアプリです。<br />
        言葉にしない気配まで、やさしくつなぐ。見守りではなく「つながり」を、管理ではなく「共感」を。
      </p>

      <div class="hero-actions">
        <a href="#monitor" class="btn btn-accent">
          <IconHome />
          モニターに参加する
        </a>
        <a href="#features" class="btn btn-secondary">詳しく見る</a>
      </div>

      <div class="hero-proof">
        <div class="avatars" aria-hidden="true">
          <span class="avatar avatar-1"></span>
          <span class="avatar avatar-2"></span>
          <span class="avatar avatar-3"></span>
        </div>
        <p class="proof-text">奈良からはじまる、三世代のつながり</p>
      </div>
    </div>

    <div class="hero-visual">
      <figure class="hero-image" aria-label="奈良の四季の風景">
        {heroImages.map((img, i) => (
          <img
            src={img.src}
            alt={img.alt}
            class={i === 0 ? 'is-active' : ''}
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        ))}
      </figure>
    </div>
  </div>
</section>

<script>
  const imgs = document.querySelectorAll<HTMLImageElement>('.hero-image img');
  if (imgs.length > 1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let idx = 0;
    setInterval(() => {
      imgs[idx].classList.remove('is-active');
      idx = (idx + 1) % imgs.length;
      imgs[idx].classList.add('is-active');
    }, 4500);
  }
</script>

<style>
  .hero {
    padding: var(--space-3xl) 0;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    gap: var(--space-2xl);
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .hero-title {
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: var(--lh-tight);
    letter-spacing: 0.012em;
    color: var(--color-text);
  }

  .hero-title-line {
    display: block;
  }

  .hero-title-emphasis {
    color: var(--color-primary);
  }

  .hero-lead {
    max-width: 560px;
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--color-text-muted);
    letter-spacing: -0.025em;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  /* Social proof row */
  .hero-proof {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-top: var(--space-md);
  }

  .avatars {
    display: inline-flex;
  }

  .avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid #ffffff;
    box-shadow: 0 0 0 1px var(--color-border-subtle);
  }

  .avatar + .avatar {
    margin-left: -7px;
  }

  .avatar-1 {
    background: var(--color-avatar-1);
  }
  .avatar-2 {
    background: var(--color-avatar-2);
  }
  .avatar-3 {
    background: var(--color-avatar-3);
  }

  .proof-text {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    letter-spacing: -0.002em;
  }

  /* Hero visual */
  .hero-visual {
    width: 100%;
  }

  .hero-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    margin: 0;
    background: var(--color-bg-soft);
  }

  .hero-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
  }

  .hero-image img.is-active {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-image img {
      transition: none;
    }
  }

  /* Tablet and up */
  @media (min-width: 768px) {
    .hero {
      padding: calc(var(--space-3xl) * 1.2) 0;
    }

    .hero-title {
      font-size: 42px;
    }
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1.1fr 1fr;
      align-items: center;
      gap: var(--space-3xl);
    }

    .hero-title {
      font-size: var(--fs-h1-lg);
    }
  }
</style>
