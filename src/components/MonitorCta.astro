---
// 家族モニター募集 — Tanect Home の家族モニター参加を呼びかける最終CTAセクション
// 申し込みフォームは廃止（同意はアプリ登録時に移設）。インストール案内がメイン導線。
// 内部リンクは base 付きで組み立てる（他ページと同じパターン）
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const INSTALL_URL = `${base}/home/install`;
const SURVEY_URL = 'https://docs.google.com/forms/d/e/1FAIpQLSd58UzNN4Wg1W-iWpn0knXfG6IdAngpkJS6EPm7O8EnWr6Iuw/viewform';
---

<section class="monitor" id="monitor" aria-labelledby="monitor-title">
  <div class="monitor-inner">
    <span class="badge monitor-badge">🌱 家族モニター募集中</span>

    <h2 class="monitor-title" id="monitor-title">
      家族のつながりを、<br />
      いっしょに育ててくれる方を募集しています。
    </h2>

    <p class="monitor-lead">
      Tanect Home はいま、最初の家族モニターのみなさんを募集しています。<br />
      離れて暮らすご家族との毎日を、やさしくつなぐ。その第一歩を、ぜひご一緒に。<br />
      なお、モニター終了後も継続してご利用いただける方が、アカウントやこれまでの記録を本番環境へ引き継げるよう、現在その仕組みを準備中です。
    </p>

    <p class="monitor-note">
      実際に使ってみて Tanect Home を知っていただき、共感できる点や「ここを直してほしい」という声をいただくこと——その改善こそが、いちばんの目的です。<br />
      お試し後にアンケートでご感想をお聞かせいただけますと、私たちにとって本当にありがたいことです。
    </p>

    <div class="monitor-period">
      <p class="monitor-period-title">🗓️ お試しいただける期間：<strong>2026年8月31日（月）まで</strong></p>
      <p class="monitor-period-body">
        この間に、毎日の記録と <strong>AI週次レポート</strong>（毎週日曜の朝9時に、前の週の記録をまとめて作成）まで、ぜひ一度は体験してみてください。どこかで1週間ほど続けて記録いただくと、日曜の朝にレポートが届きます。
      </p>
    </div>

    <div class="monitor-actions">
      <div class="monitor-action">
        <a
          href={INSTALL_URL}
          class="btn btn-accent monitor-cta"
          data-track-event="monitor_install_click"
        >
          <span class="monitor-cta-emoji" aria-hidden="true">📱</span>
          アプリの<wbr />入れかたを見る
        </a>
      </div>

      <div class="monitor-action">
        <a
          href={SURVEY_URL}
          class="btn btn-secondary monitor-cta"
          target="_blank"
          rel="noopener"
          data-track-event="monitor_survey_click"
        >
          <span class="monitor-cta-emoji" aria-hidden="true">📝</span>
          お試し後の<wbr />アンケート
        </a>
        <p class="monitor-subnote">利用後に、ご家族みなさんからお聞かせください</p>
      </div>
    </div>
  </div>
</section>

<style>
  .monitor {
    padding: var(--space-3xl) var(--space-md);
  }

  .monitor-inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: var(--space-3xl) var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    text-align: center;
    background: linear-gradient(150deg, var(--color-accent-soft) 0%, #ffffff 70%);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .monitor-badge {
    background: #ffffff;
    color: var(--color-accent-ink);
  }

  .monitor-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text);
    letter-spacing: 0.012em;
  }

  .monitor-lead {
    max-width: 600px;
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  /* 運営の姿勢：引き止めではなく、理解・共感・改善が目的であることを伝える */
  .monitor-note {
    max-width: 600px;
    padding: var(--space-md) var(--space-lg);
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-text);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md);
  }

  /* お試し期間の明示：いつまでに試すか・週次レポート体験の導線 */
  .monitor-period {
    max-width: 600px;
    padding: var(--space-md) var(--space-lg);
    background: #ffffff;
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md);
  }

  .monitor-period-title {
    font-size: var(--fs-body);
    font-weight: 700;
    color: var(--color-accent-ink);
    margin-bottom: var(--space-xs);
  }

  .monitor-period-body {
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-text);
  }

  .monitor-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    margin-top: var(--space-sm);
    width: 100%;
  }

  /* ボタン＋補足文のペア（対象者ごとの導線） */
  .monitor-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .monitor-cta {
    font-size: var(--fs-body);
    padding: var(--space-md) var(--space-2xl);
    /* 文節の途中で折らず、<wbr> を入れた位置でのみ改行する */
    word-break: keep-all;
  }

  .monitor-cta-emoji {
    font-size: 1.1em;
    line-height: 1;
  }

  .monitor-subnote {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* Tablet and up */
  @media (min-width: 768px) {
    .monitor-title {
      font-size: 34px;
    }
  }
</style>
