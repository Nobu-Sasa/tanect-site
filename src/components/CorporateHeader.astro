---
// タネクト コーポレートヘッダー — コーポレートトップ・About・法務ページ等で使用。
// LP（/home/ 配下）は従来の Header.astro（モニターCTA付き）を使う。
import TanectMark from './TanectMark.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: `${base}/home/`, label: 'Tanect Home' },
  { href: `${base}/dev-support`, label: '開発支援' },
  { href: `${base}/about`, label: 'タネクトについて' },
  { href: `${base}/company`, label: '会社概要' },
];
---

<header class="header">
  <div class="header-inner">
    <a href={import.meta.env.BASE_URL} class="logo" aria-label="タネクト（Tanect）トップへ">
      <span class="logo-mark">
        <TanectMark size={30} />
      </span>
      <span class="logo-text">Tanect</span>
    </a>

    <nav id="site-nav" class="nav" aria-label="メインナビゲーション">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <a href={`${base}/contact`} class="btn btn-primary btn-sm">お問い合わせ</a>

      <button
        type="button"
        class="nav-toggle"
        aria-label="メニューを開く"
        aria-controls="site-nav"
        aria-expanded="false"
      >
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>
    </div>
  </div>
</header>

<script>
  document.querySelectorAll('.nav-toggle').forEach((btn) => {
    const header = btn.closest('.header');
    if (!header) return;
    const setOpen = (open: boolean) => {
      header.classList.toggle('nav-open', open);
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');
    };
    btn.addEventListener('click', () => {
      setOpen(!header.classList.contains('nav-open'));
    });
    // リンクを選んだら閉じる
    header.querySelectorAll('.nav-link').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
  });
</script>

<style define:vars={{ headerBg: `url('${base}/images/header-landscape.png')` }}>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    /* 名刺裏（TanectBack5）の山並みを帯として敷く。上に白のグラデを重ねて可読性を確保。 */
    background-image:
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.78) 0%,
        rgba(255, 255, 255, 0.5) 55%,
        rgba(255, 255, 255, 0.28) 100%
      ),
      var(--headerBg);
    background-size: 100% 100%, 100% 100%;
    background-repeat: no-repeat, no-repeat;
    background-position: center, center bottom;
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    max-width: var(--container-max);
    margin-inline: auto;
    /* 下側に余白を足し、ナビ行の下に山並みの帯が覗くようにする */
    padding: var(--space-md) var(--space-md) calc(var(--space-md) + 22px);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-weight: 700;
  }

  .logo-mark {
    display: inline-flex;
    color: var(--color-primary); /* マーク色は暫定（色は別途相談中） */
  }

  .logo-text {
    font-size: 20px;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  .nav {
    display: none;
    gap: var(--space-xl);
  }

  .nav-link {
    font-size: 14px;
    color: #000;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--color-primary);
  }

  .btn-sm {
    padding: 8px 16px;
    font-size: 13px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  /* ハンバーガーボタン（モバイルのみ表示） */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 0 9px;
    border: 1px solid var(--color-border-subtle);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.6);
    cursor: pointer;
  }

  .nav-toggle-bar {
    height: 2px;
    width: 100%;
    background: #000;
    border-radius: 2px;
    transition:
      transform var(--duration-fast) var(--ease-out),
      opacity var(--duration-fast) var(--ease-out);
  }

  /* Mobile：ハンバーガー表示＋ドロップダウン（768px 未満に限定） */
  @media (max-width: 767.98px) {
    .nav-toggle {
      display: inline-flex;
    }

    /* 開いたとき、3本線を×印に */
    .header.nav-open .nav-toggle-bar:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .header.nav-open .nav-toggle-bar:nth-child(2) {
      opacity: 0;
    }
    .header.nav-open .nav-toggle-bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .header.nav-open .nav {
      display: flex;
      flex-direction: column;
      gap: 0;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: saturate(180%) blur(10px);
      -webkit-backdrop-filter: saturate(180%) blur(10px);
      border-bottom: 1px solid var(--color-border-subtle);
      padding: 0 var(--space-md) var(--space-sm);
    }

    .header.nav-open .nav .nav-link {
      padding: var(--space-md) 0;
      border-top: 1px solid var(--color-border-subtle);
      font-size: 15px;
    }
  }

  /* Tablet and up */
  @media (min-width: 768px) {
    .nav {
      display: flex;
    }

    .btn-sm {
      padding: 10px 20px;
      font-size: 14px;
    }
  }
</style>
