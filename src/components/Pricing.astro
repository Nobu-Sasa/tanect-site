---
// 料金 — 正式リリース後に予定している有料プラン（家族モニター期間中は無料）
import IconHome from './icons/IconHome.astro';

type Plan = {
  name: string;
  monthlyYen: number;
  capacity: number; // 登録できる人数（上限・グループ合計）
  groups?: number; // 登録できる家族グループ数の上限（省略時は1）
  description: string;
  features: string[];
  featured?: boolean;
  badge?: string;
  cta?: { label: string; href: string };
  note?: string;
};

const plans: Plan[] = [
  {
    name: '基本プラン',
    monthlyYen: 480,
    capacity: 3,
    description: 'まずは気軽に。少人数のご家族で。',
    features: [
      '記録・みんなの活動・地図・いいね',
      'AI分析（活動を見る）',
      'プッシュ通知',
      '過去の記録の閲覧 6ヶ月',
    ],
  },
  {
    name: '上位プラン',
    monthlyYen: 980,
    capacity: 6,
    groups: 2,
    featured: true,
    badge: 'おすすめ',
    description: 'AI週次レポートと画像投票で、家族みんなで。',
    features: [
      '基本プランのすべて',
      'ご家族6人まで登録できる',
      '2つのご家族グループを登録できる（例：自分の親＋配偶者の親）',
      '画像投票に参加できる',
      '今週の家族・AI週次レポート・過去レポートの閲覧',
      '過去の記録の閲覧 1年',
    ],
  },
  {
    name: 'プレミアムプラン',
    monthlyYen: 1480,
    capacity: 9,
    groups: 3,
    description: '大家族でも、思い出をもっと深く・長く。',
    features: [
      '上位プランのすべて',
      'ご家族9人・3つのご家族グループまで登録できる',
      '思い出発見（家族の思い出をAIにたずねられる）',
      'AIアシスタント連携（順次対応予定）',
      '過去の記録の閲覧 3年',
    ],
  },
];

// 表示ヘルパー（金額の手打ちズレを防ぐため一元計算）
const yen = (n: number) => n.toLocaleString('ja-JP');
const perPerson = (p: Plan) => Math.round(p.monthlyYen / p.capacity);
---

<section class="pricing" id="pricing" aria-labelledby="pricing-title">
  <div class="pricing-inner">
    <header class="pricing-head">
      <span class="badge">💴 料金</span>
      <h2 class="pricing-title" id="pricing-title">
        正式リリース後の<wbr />料金プラン
      </h2>
      <p class="pricing-lead">
        Tanect Home はいま、サービスとして続けていけるかを確かめる「家族モニター」の段階です。期間中は無料でお使いいただけます。<br />
        下記は、正式リリース時に予定している料金プランの<strong>たたき台</strong>です。金額はまだ検討中で、モニターのみなさんのご意見をうかがいながら調整していきます。
      </p>
    </header>

    <p class="pricing-trial">
      正式リリース後は、はじめの3週間を無料でお試しいただけます。<br />
      ダウンロードしてご家族をひとつ登録すると、お試し期間がはじまります。
    </p>

    <ul class="plan-grid">
      {plans.map((plan) => (
        <li class={`plan ${plan.featured ? 'is-featured' : ''}`}>
          {plan.badge && <span class="plan-badge">{plan.badge}</span>}
          <h3 class="plan-name">{plan.name}</h3>
          <p class="plan-price">
            <span class="plan-price-row">
              <span class="plan-price-value">{yen(plan.monthlyYen)}円</span>
              <span class="plan-price-tag">検討中</span>
            </span>
            <span class="plan-price-note">
              {`月額・最大${plan.capacity}人（${plan.groups ?? 1}家族グループまで）`}
            </span>
            <span class="plan-price-per-person">
              {plan.capacity}人で使うと、1人あたり<strong>約{yen(perPerson(plan))}円</strong>/月（参考）
            </span>
          </p>
          <p class="plan-desc">{plan.description}</p>
          <ul class="plan-features">
            {plan.features.map((f) => (
              <li class="plan-feature">
                <span class="plan-check" aria-hidden="true">✓</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          {plan.cta && (
            <a href={plan.cta.href} class="btn btn-accent plan-cta">
              <IconHome size={18} />
              {plan.cta.label}
            </a>
          )}
          {plan.note && <p class="plan-note">{plan.note}</p>}
        </li>
      ))}
    </ul>

    <p class="plan-grid-note">
      ※ 料金はすべて検討中のもので、今後変更になる場合があります。<br />
      ※ 料金は1つのお支払いあたりの月額です（登録できる人数はプランによって異なります：基本プラン 3人まで／上位プラン 6人まで／プレミアムプラン 9人まで）。<br />
      ※ 上位・プレミアムプランは、はなれて暮らす<strong>別々のご家族グループ</strong>（上位は2つ・プレミアムは3つまで）を1つのお支払いで登録できます（例：ご自身の親と配偶者の親。それぞれの記録は混ざりません）。<br />
      ※「1人あたり」の金額は、各プランの上限人数で使った場合の参考値です。
    </p>
  </div>
</section>

<style>
  .pricing {
    padding: var(--space-3xl) 0;
    background: var(--color-bg-soft);
  }

  .pricing-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  .pricing-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .pricing-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    line-height: var(--lh-tight);
    color: var(--color-text);
    letter-spacing: 0.012em;
    /* 文節の途中で折らず、<wbr> を入れた位置でのみ改行する */
    word-break: keep-all;
  }

  .pricing-lead {
    max-width: 640px;
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .pricing-trial {
    max-width: 640px;
    margin: 0 auto var(--space-2xl);
    padding: var(--space-md) var(--space-lg);
    text-align: center;
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md);
  }

  .plan-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .plan-grid-note {
    margin-top: var(--space-lg);
    text-align: center;
    font-size: var(--fs-small);
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .plan {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-xl);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .plan.is-featured {
    border: 2px solid var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .plan-badge {
    position: absolute;
    top: calc(var(--space-md) * -1);
    left: var(--space-xl);
    display: inline-flex;
    align-items: center;
    padding: 4px 14px;
    background: var(--color-accent);
    color: var(--color-accent-text);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: var(--radius-pill);
    box-shadow: 0 2px 6px rgba(252, 163, 81, 0.4);
  }

  .plan-name {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0.012em;
  }

  .plan-price {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .plan-price-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .plan-price-value {
    font-size: 36px;
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text);
  }

  .is-featured .plan-price-value {
    color: var(--color-accent-ink);
  }

  /* 「検討中」タグ：金額がまだ確定でないことを明示 */
  .plan-price-tag {
    align-self: center;
    padding: 2px 10px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-accent-ink);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-pill);
  }

  .plan-price-note {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  /* 1人あたりの参考値 */
  .plan-price-per-person {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }

  .plan-price-per-person strong {
    color: var(--color-text);
    font-weight: 700;
  }

  .plan-desc {
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .plan-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border-subtle);
  }

  .plan-feature {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text);
  }

  .plan-check {
    color: var(--color-accent-ink);
    font-weight: 700;
    flex-shrink: 0;
  }

  .plan-cta {
    margin-top: var(--space-sm);
    width: 100%;
  }

  .plan-note {
    font-size: var(--fs-small);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* Tablet and up */
  @media (min-width: 768px) {
    .pricing-title {
      font-size: 36px;
    }
  }

  /* Desktop */
  @media (min-width: 768px) {
    .plan-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
      max-width: 1080px;
      margin-inline: auto;
    }
  }
</style>
