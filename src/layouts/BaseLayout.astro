---
import '../styles/global.css';
import { GA_MEASUREMENT_ID } from '../config';

export interface Props {
  title?: string;
  description?: string;
  /** 検索エンジンに載せないページは true（既定）。正式公開時にページ単位で false にして段階的に解除する。 */
  noindex?: boolean;
}

const {
  title = 'Tanect Home — 日々のあゆみを、家族とつなぐ',
  description = '離れて暮らすご家族と、日々のあゆみをそっと共有するアプリ。言葉にしない気配まで、やさしくつなぐ。見守りではなく、つながりを。',
  noindex = true,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* 家族モニター（検証）期間中は検索エンジンに載せない（noindex prop 既定 true）。
        正式公開時はページ側で noindex={false} を渡して段階的に解除する（robots.txt の解除も忘れずに）。 */}
    {noindex && (
      <Fragment>
        <meta name="robots" content="noindex, nofollow" />
        <meta name="googlebot" content="noindex, nofollow" />
      </Fragment>
    )}
    <meta name="description" content={description} />
    {/* favicon はコーポレートマーク。SVG が第一候補（ダークモードで白線に反転）、PNG は Safari 等のフォールバック（白地に黒線）。 */}
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="192x192" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon-192.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon-192.png`} />

    <!-- Fonts: Inter (latin) + Noto Sans JP (日本語) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="ja_JP" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {/* GA4: 測定IDが設定されているときだけ読み込む（config.ts の GA_MEASUREMENT_ID） */}
    {GA_MEASUREMENT_ID && (
      <Fragment>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
        <script is:inline define:vars={{ gaId: GA_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { window.dataLayer.push(arguments); }
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </Fragment>
    )}
  </head>
  <body>
    <slot />

    {/* CTAクリック計測：data-track-event を持つ要素のクリックを GA4 イベントとして送る。
        gtag 未定義（GA_MEASUREMENT_ID 未設定）のときは何もしない。 */}
    <script>
      document.addEventListener('click', (e) => {
        const el = (e.target as HTMLElement)?.closest<HTMLElement>('[data-track-event]');
        if (!el) return;
        const eventName = el.dataset.trackEvent;
        const gtag = (window as unknown as { gtag?: (...args: unknown[]) => void }).gtag;
        if (!eventName || typeof gtag !== 'function') return;
        gtag('event', eventName, {
          cta_location: el.dataset.ctaLocation || undefined,
        });
      });
    </script>
  </body>
</html>
